<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>Kuestenlogik.Surgewave.Templates</PackageId>
    <Description>dotnet new templates for Surgewave plugin authoring: broker plugin, protocol plugin, storage engine plugin. Install with `dotnet new install Kuestenlogik.Surgewave.Templates`, then scaffold with e.g. `dotnet new surgewave-broker-plugin --name MyPlugin`.</Description>
    <PackageTags>surgewave;dotnet-new;templates;plugins;scaffold</PackageTags>
    <TargetFramework>net10.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <!-- Template packages have no lib/ output; suppress the NuGet validator warning. -->
    <NoWarn>$(NoWarn);NU5128;NU5119</NoWarn>
    <NoDefaultExcludes>true</NoDefaultExcludes>
  </PropertyGroup>

  <ItemGroup>
    <!-- Map content/<template-name>/... in the source tree directly to
         content/<template-name>/... in the nupkg (NuGet's convention for
         dotnet-new template packages). The %(RecursiveDir) preserves the
         template-folder name and any nested structure. -->
    <Content Include="content\**\*" Exclude="content\**\bin\**;content\**\obj\**">
      <PackagePath>content\%(RecursiveDir)%(Filename)%(Extension)</PackagePath>
    </Content>
    <Compile Remove="**\*" />
  </ItemGroup>

</Project>
