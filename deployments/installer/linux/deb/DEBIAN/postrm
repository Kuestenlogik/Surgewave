#!/bin/bash
set -e

if [ "$1" = "purge" ]; then
    # Remove data and config on purge
    rm -rf /var/lib/surgewave
    rm -rf /var/log/surgewave
    rm -rf /etc/surgewave

    # Remove user
    userdel surgewave 2>/dev/null || true
    groupdel surgewave 2>/dev/null || true
fi

systemctl daemon-reload
