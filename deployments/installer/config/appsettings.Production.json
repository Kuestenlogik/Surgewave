{
  "Surgewave": {
    "DefaultReplicationFactor": 1,
    "DefaultNumPartitions": 3,
    "LogRetentionHours": 168,
    "AutoCreateTopics": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Kuestenlogik.Surgewave": "Information"
    }
  }
}
