<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>
    <!-- Empty directory components so WiX creates them during install -->

    <Component Id="DataDirComponent" Directory="DataDir" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
      <CreateFolder />
    </Component>

    <Component Id="LogsDirComponent" Directory="LogsDir" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
      <CreateFolder />
    </Component>

    <Component Id="PluginsDirComponent" Directory="PluginsDir" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
      <CreateFolder />
    </Component>

    <Component Id="ModelsDirComponent" Directory="ModelsDir" Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
      <CreateFolder />
    </Component>

    <Component Id="WasmDirComponent" Directory="WasmDir" Guid="E5F6A7B8-C9D0-1234-EFAB-345678901234">
      <CreateFolder />
    </Component>
  </Fragment>

</Wix>
