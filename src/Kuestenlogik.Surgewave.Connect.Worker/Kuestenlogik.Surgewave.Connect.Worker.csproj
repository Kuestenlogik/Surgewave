<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Kuestenlogik.Surgewave.Connect.Worker</RootNamespace>
    <IsPackable>false</IsPackable>
    <AssemblyName>surgewave-connect</AssemblyName>
  </PropertyGroup>

  <!-- Publish-specific settings for optimized/trimmed builds -->
  <!-- No trimming — Worker uses Reflection (plugin loading, connector instantiation) -->
  <!-- Use: dotnet publish -c Release -p:Optimized=true -r win-x64 -->
  <PropertyGroup Condition="'$(Optimized)' == 'true'">
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
    <ReadyToRun>true</ReadyToRun>
    <OptimizationPreference>Speed</OptimizationPreference>
    <DebuggerSupport>false</DebuggerSupport>
    <EnableUnsafeUTF7Encoding>false</EnableUnsafeUTF7Encoding>
    <HttpActivityPropagationSupport>false</HttpActivityPropagationSupport>
    <MetadataUpdaterSupport>false</MetadataUpdaterSupport>
  </PropertyGroup>

  <!-- Container Publishing (.NET Native) -->
  <PropertyGroup>
    <ContainerRepository>surgewave/surgewave-connect</ContainerRepository>
    <ContainerImageTag>$(Version)</ContainerImageTag>
    <ContainerBaseImage>mcr.microsoft.com/dotnet/aspnet:10.0</ContainerBaseImage>
    <ContainerFamily>jammy</ContainerFamily>
  </PropertyGroup>

  <ItemGroup Label="Container Ports">
    <ContainerPort Include="8083" Type="tcp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Connect\Kuestenlogik.Surgewave.Connect.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Client\Kuestenlogik.Surgewave.Client.csproj" />
    <!-- #59: the standalone Connect worker builds a Kafka-wire client (UseKafkaProtocol),
         resolved from Client.Kafka by reflection at runtime — reference it so the dll is
         present in this worker's bin. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Client.Kafka\Kuestenlogik.Surgewave.Client.Kafka.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Api.Grpc\Kuestenlogik.Surgewave.Api.Grpc.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Api.Grpc.Server\Kuestenlogik.Surgewave.Api.Grpc.Server.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Plugins.Packaging.Hosting\Kuestenlogik.Surgewave.Plugins.Packaging.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Grpc.JsonTranscoding" />
  </ItemGroup>

</Project>
