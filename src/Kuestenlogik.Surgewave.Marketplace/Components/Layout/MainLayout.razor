@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Large" Class="mr-2" />
        <MudText Typo="Typo.h6">Surgewave Marketplace</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Upload" Color="Color.Inherit" Href="/publish" />
    </MudAppBar>
    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>
