{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Gateway": {
    "DefaultCluster": "local",
    "Clusters": {
      "local": {
        "BrokerHost": "localhost",
        "BrokerPort": 9092,
        "EnablePipelining": true
      }
    }
  }
}
