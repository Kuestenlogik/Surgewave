{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "DefaultCluster": "surgewave-cluster",
    "Clusters": {
      "surgewave-cluster": {
        "BrokerHost": "localhost",
        "BrokerPort": 9092,
        "EnablePipelining": true
      }
    },
    "ConnectionTimeoutMs": 30000,
    "RequestTimeoutMs": 30000
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:8082"
      },
      "Https": {
        "Url": "https://*:8443",
        "Protocols": "Http1AndHttp2AndHttp3"
      }
    }
  },
  "Telemetry": {
    "ServiceName": "Kuestenlogik.Surgewave.Gateway",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Enabled": false,
      "Endpoint": "http://localhost:4317",
      "Protocol": "Grpc"
    },
    "Prometheus": {
      "Enabled": true,
      "Path": "/metrics"
    },
    "Tracing": {
      "SamplingRatio": 1.0,
      "IncludeAspNetCore": true,
      "IncludeGrpc": true
    }
  }
}
