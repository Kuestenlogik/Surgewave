{
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "https://*:9093",
        "Protocols": "Http1AndHttp2"
      },
      "GrpcHttp3": {
        "Url": "https://*:9094",
        "Protocols": "Http1AndHttp2AndHttp3"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Surgewave": {
    "BrokerId": 0,
    "Host": "localhost",
    "Port": 9092,
    "GrpcPort": 9093,
    "GrpcUseTls": true,
    "DataDirectory": "./data",
    "LogDirectory": "./logs",
    "MaxConnectionsPerIp": 100,
    "SocketSendBufferBytes": 102400,
    "SocketReceiveBufferBytes": 102400,
    "MaxRequestSize": 104857600,
    "LogSegmentBytes": 1073741824,
    "LogRetentionHours": 168,
    "LogRetentionBytes": -1,
    "AutoCreateTopics": true,
    "DefaultReplicationFactor": 1,
    "DefaultNumPartitions": 1,
    "ProducerBatchSizeBytes": 16384,
    "ProducerLingerMs": 5,
    "ProducerMaxBatchMessages": 10000,
    "NativeProtocolCompressionEnabled": true,
    "SimdBatchThreshold": 4,
    "UseChannelPipeline": true,
    "ChannelWriteWorkers": 4,
    "ChannelReadWorkers": 8,
    "ChannelWriteBufferSize": 10000,
    "ChannelWriteBatchSize": 100,
    "ChannelWriteBatchDelayMs": 10,
    "Quotas": {
      "Enabled": false,
      "ProducerBytesPerSecond": -1,
      "ProducerBurstBytes": 104857600,
      "ConsumerBytesPerSecond": -1,
      "ConsumerBurstBytes": 104857600,
      "MaxThrottleTimeMs": 30000,
      "ClientInactivityTimeoutMinutes": 10
    },
    "PostgreSql": {
      "Enabled": false,
      "Port": 5432,
      "RequirePassword": false,
      "MaxConnections": 100,
      "ServerVersion": "16.0"
    },
    "Connect": {
      "Enabled": true,
      "GroupId": "surgewave-connect",
      "ConfigTopic": "surgewave-connect-configs",
      "OffsetsTopic": "surgewave-connect-offsets",
      "StatusTopic": "surgewave-connect-status"
    }
  },
  "Telemetry": {
    "ServiceName": "Kuestenlogik.Surgewave.Broker",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Enabled": false,
      "Endpoint": "http://localhost:4317",
      "Protocol": "Grpc"
    },
    "Prometheus": {
      "Enabled": true
    },
    "Tracing": {
      "SamplingRatio": 1.0,
      "IncludeAspNetCore": true
    }
  }
}
