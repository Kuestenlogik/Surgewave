{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5050"
      }
    }
  },
  "Gateway": {
    "BaseUrl": "http://localhost:8082"
  },
  "UI": {
    "MetricsRefreshIntervalSeconds": 5,
    "DefaultClusterId": "surgewave-cluster"
  },
  "Auth": {
    "Enabled": false,
    "AdminRole": "surgewave-admin",
    "Providers": []
  }
}
