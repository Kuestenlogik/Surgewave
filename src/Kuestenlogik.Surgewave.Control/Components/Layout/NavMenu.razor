        <MudNavLink Href="/acls" Icon="@Icons.Material.Filled.AdminPanelSettings">ACLs</MudNavLink>
        <MudNavLink Href="/quotas" Icon="@Icons.Material.Filled.Speed">Quotas</MudNavLink>
