    </MudNavGroup>

    <MudNavGroup Title="Monitoring" Icon="@Icons.Material.Filled.Insights" Expanded="false">
        <MudNavLink Href="/metrics" Icon="@Icons.Material.Filled.QueryStats">Metrics</MudNavLink>
        <MudNavLink Href="/consumer-lag" Icon="@Icons.Material.Filled.TrendingDown">Consumer Lag</MudNavLink>
        <MudNavLink Href="/alerts" Icon="@Icons.Material.Filled.NotificationsActive">Alerts</MudNavLink>
        <MudNavLink Href="/performance-advisor" Icon="@Icons.Material.Filled.AutoFixHigh">Performance Advisor</MudNavLink>
