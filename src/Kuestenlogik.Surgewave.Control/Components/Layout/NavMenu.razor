        <MudNavLink Href="/debug/timeline" Icon="@Icons.Material.Filled.Timeline">Timeline Debugger</MudNavLink>
    </MudNavGroup>

    @* Dynamic plugin nav items *@
    @foreach (var group in _pluginNavGroups)
    {
        <MudNavGroup Title="@group.Key" Icon="@Icons.Material.Filled.Extension" Expanded="false">
            @foreach (var item in group)
            {
                <MudNavLink Href="@item.Href" Icon="@item.Icon">@item.Title</MudNavLink>
            }
        </MudNavGroup>
    }

    <MudDivider Class="my-2" />

    <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
    <MudNavLink Href="/help" Icon="@Icons.Material.Filled.Help">Help Center</MudNavLink>
</MudNavMenu>

@code {
    [Inject] private ControlPluginRegistry PluginRegistry { get; set; } = null!;

    private ILookup<string, Kuestenlogik.Surgewave.Plugins.ControlNavItem> _pluginNavGroups =
        Enumerable.Empty<Kuestenlogik.Surgewave.Plugins.ControlNavItem>().ToLookup(_ => "");

    protected override void OnInitialized()
    {
        _pluginNavGroups = PluginRegistry.NavItems
            .ToLookup(n => n.Group ?? "Plugins");
    }
}
