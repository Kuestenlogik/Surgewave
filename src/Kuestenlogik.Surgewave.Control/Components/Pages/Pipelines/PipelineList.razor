@page "/pipelines"
@rendermode InteractiveServer
@using Kuestenlogik.Surgewave.Control.Models.Pipeline
@using Kuestenlogik.Surgewave.Control.Services
@using Kuestenlogik.Surgewave.Control.Components.Pipeline
@inject IPipelineApiClient ApiClient
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject NotificationState Notification

<PageTitle>Pipelines - Surgewave Control</PageTitle>

<PageHead Title="Pipelines"
          Subtitle="AI + data pipelines composed from connectors and processors.">
    <Actions>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.DeviceHub" Href="/pipelines/lineage">
            Lineage
        </MudButton>
        <AuthorizeView Policy="@SurgewavePolicies.PipelinesManage">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Upload" OnClick="ShowImportDialog">
                Import
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Article" OnClick="ShowTemplatesDialog">
                Templates
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewPipeline">
                Create pipeline
            </MudButton>
        </AuthorizeView>
    </Actions>
</PageHead>

<div class="d-flex align-center gap-3 mb-3">
    <MudTextField @bind-Value="_searchText" Placeholder="Search pipelines…" Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Margin="Margin.Dense" Class="flex-grow-1"
                  Immediate="true" DebounceInterval="300" />
    <MudSelect T="PipelineStatus?" @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined"
               Margin="Margin.Dense" Style="width: 180px;">
        <MudSelectItem T="PipelineStatus?" Value="@((PipelineStatus?)null)">All</MudSelectItem>
        <MudSelectItem T="PipelineStatus?" Value="@((PipelineStatus?)PipelineStatus.Draft)">Draft</MudSelectItem>
        <MudSelectItem T="PipelineStatus?" Value="@((PipelineStatus?)PipelineStatus.Running)">Running</MudSelectItem>
        <MudSelectItem T="PipelineStatus?" Value="@((PipelineStatus?)PipelineStatus.Stopped)">Stopped</MudSelectItem>
        <MudSelectItem T="PipelineStatus?" Value="@((PipelineStatus?)PipelineStatus.Failed)">Failed</MudSelectItem>
    </MudSelect>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        @_error
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadPipelinesAsync" Class="ml-4">
            Retry
        </MudButton>
    </MudAlert>
}
else
{
    <MudPaper Class="surgewave-surface" Style="padding: 0;">
    <MudTable Items="@FilteredPipelines" Dense="true" Hover="true" Striped="false" Elevation="0">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<PipelineDefinition, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh>Status</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PipelineDefinition, object>(x => x.Nodes.Count)">Nodes</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PipelineDefinition, object>(x => x.CreatedAt)">Created</MudTableSortLabel></MudTh>
            <MudTh Style="width: 200px">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudLink Href="@($"/pipelines/{context.Id}/edit")">@context.Name</MudLink>
                @if (!string.IsNullOrEmpty(context.Description))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Status">
                <span class="surgewave-status @GetStatusStatusClass(context.Status)">
                    <span class="surgewave-status-dot"></span>
                    @context.Status
                </span>
                @if (context.Schedule is { Enabled: true })
                {
                    <span class="surgewave-status surgewave-status--info ml-2">
                        <span class="surgewave-status-dot"></span>
                        @if (context.Schedule.NextRunAt.HasValue)
                        {
                            @($"Next: {context.Schedule.NextRunAt.Value.LocalDateTime:g}")
                        }
                        else
                        {
                            @("Scheduled")
                        }
                    </span>
                }
            </MudTd>
            <MudTd DataLabel="Nodes"><span class="surgewave-mono">@context.Nodes.Count</span></MudTd>
            <MudTd DataLabel="Created"><span class="surgewave-mono">@context.CreatedAt.LocalDateTime.ToString("g")</span></MudTd>
            <MudTd DataLabel="Actions">
                <AuthorizeView Policy="@SurgewavePolicies.PipelinesManage" Context="auth">
                    @if (context.Status == PipelineStatus.Running)
                    {
                        <MudTooltip Text="Stop pipeline">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                           OnClick="@(() => StopPipelineAsync(context))" />
                        </MudTooltip>
                    }
                    else
                    {
                        <MudTooltip Text="Start pipeline">
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                           OnClick="@(() => StartPipelineAsync(context))" />
                        </MudTooltip>
                    }
                </AuthorizeView>
                <MudTooltip Text="Edit pipeline">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   Href="@($"/pipelines/{context.Id}/edit")" />
                </MudTooltip>
                <MudTooltip Text="Monitor pipeline">
                    <MudIconButton Icon="@Icons.Material.Filled.MonitorHeart" Size="Size.Small"
                                   Href="@($"/pipelines/{context.Id}/monitor")"
                                   Disabled="@(context.Status != PipelineStatus.Running)" />
                </MudTooltip>
                <MudTooltip Text="Execution history">
                    <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small"
                                   Href="@($"/pipelines/{context.Id}/history")" />
                </MudTooltip>
                @if (HasChatEndpoint(context))
                {
                    <MudTooltip Text="Chat with pipeline">
                        <MudIconButton Icon="@Icons.Material.Filled.Chat" Size="Size.Small"
                                       Color="Color.Primary"
                                       Href="@($"/pipelines/{context.Id}/chat")" />
                    </MudTooltip>
                }
                <MudTooltip Text="Export pipeline">
                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                   OnClick="@(() => ShowExportDialog(context))" />
                </MudTooltip>
                <AuthorizeView Policy="@SurgewavePolicies.PipelinesManage" Context="auth">
                    <MudTooltip Text="Delete pipeline">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => ConfirmDeleteAsync(context))"
                                       Disabled="@(context.Status == PipelineStatus.Running)" />
                    </MudTooltip>
                </AuthorizeView>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Color="Color.Secondary" Class="pa-4">No pipelines found. Create one to get started.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string _searchText = "";
    private PipelineStatus? _statusFilter;
    private List<PipelineDefinition> _pipelines = [];

    private IEnumerable<PipelineDefinition> FilteredPipelines => _pipelines
        .Where(p => string.IsNullOrWhiteSpace(_searchText) ||
                    p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(p => _statusFilter == null || p.Status == _statusFilter);

    protected override async Task OnInitializedAsync()
    {
        await LoadPipelinesAsync();
    }

    private async Task LoadPipelinesAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _pipelines = (await ApiClient.ListPipelinesAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void CreateNewPipeline()
    {
        Navigation.NavigateTo("/pipelines/new");
    }

    private async Task StartPipelineAsync(PipelineDefinition pipeline)
    {
        try
        {
            await ApiClient.StartPipelineAsync(pipeline.Id);
            Notification.ShowSuccess($"Pipeline '{pipeline.Name}' started");
            await LoadPipelinesAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to start pipeline: {ex.Message}");
        }
    }

    private async Task StopPipelineAsync(PipelineDefinition pipeline)
    {
        try
        {
            await ApiClient.StopPipelineAsync(pipeline.Id);
            Notification.ShowSuccess($"Pipeline '{pipeline.Name}' stopped");
            await LoadPipelinesAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to stop pipeline: {ex.Message}");
        }
    }

    private async Task ConfirmDeleteAsync(PipelineDefinition pipeline)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Are you sure you want to delete pipeline '{pipeline.Name}'? This action cannot be undone." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Pipeline", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await DeletePipelineAsync(pipeline);
        }
    }

    private async Task DeletePipelineAsync(PipelineDefinition pipeline)
    {
        try
        {
            await ApiClient.DeletePipelineAsync(pipeline.Id);
            Notification.ShowSuccess($"Pipeline '{pipeline.Name}' deleted");
            await LoadPipelinesAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to delete pipeline: {ex.Message}");
        }
    }

    private static bool HasChatEndpoint(PipelineDefinition pipeline)
        => pipeline.Nodes.Any(n => n.ConnectorType.Contains("ChatEndpoint", StringComparison.OrdinalIgnoreCase));

    private Color GetStatusColor(PipelineStatus status) => status switch
    {
        PipelineStatus.Draft => Color.Default,
        PipelineStatus.Running => Color.Success,
        PipelineStatus.Stopped => Color.Warning,
        PipelineStatus.Failed => Color.Error,
        _ => Color.Default
    };

    private static string GetStatusStatusClass(PipelineStatus status) => status switch
    {
        PipelineStatus.Draft => "surgewave-status--idle",
        PipelineStatus.Running => "surgewave-status--ok",
        PipelineStatus.Stopped => "surgewave-status--warn",
        PipelineStatus.Failed => "surgewave-status--error",
        _ => ""
    };

    private async Task ShowImportDialog()
    {
        var parameters = new DialogParameters<ImportExportDialog>
        {
            { x => x.Mode, ImportExportDialog.ImportExportMode.Import }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportExportDialog>("Import Pipeline", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: PipelineDefinition pipeline })
        {
            Navigation.NavigateTo($"/pipelines/{pipeline.Id}/edit");
        }
    }

    private async Task ShowTemplatesDialog()
    {
        var parameters = new DialogParameters<ImportExportDialog>
        {
            { x => x.Mode, ImportExportDialog.ImportExportMode.Template }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportExportDialog>("Create from Template", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: PipelineDefinition pipeline })
        {
            Navigation.NavigateTo($"/pipelines/{pipeline.Id}/edit");
        }
    }

    private async Task ShowExportDialog(PipelineDefinition pipeline)
    {
        var parameters = new DialogParameters<ImportExportDialog>
        {
            { x => x.Mode, ImportExportDialog.ImportExportMode.Export },
            { x => x.PipelineId, pipeline.Id },
            { x => x.PipelineName, pipeline.Name }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<ImportExportDialog>("Export Pipeline", parameters, options);
    }
}
