    // Undo/Redo
    private void SaveStateForUndo(string description)
    {
        var nodes = _diagram.Nodes.OfType<ConnectorNode>();
        var links = _diagram.Links.OfType<PipelineLink>();
        _editorState.SaveState(nodes, links, description);
        _isDirty = true;
    }

    private void Undo()
    {
        var nodes = _diagram.Nodes.OfType<ConnectorNode>();
        var links = _diagram.Links.OfType<PipelineLink>();
        var snapshot = _editorState.Undo(nodes, links);
        if (snapshot != null)
        {
            RestoreSnapshot(snapshot);
            Notification.ShowInfo("Undo: " + snapshot.Description);
        }
    }

    private void Redo()
    {
        var nodes = _diagram.Nodes.OfType<ConnectorNode>();
        var links = _diagram.Links.OfType<PipelineLink>();
        var snapshot = _editorState.Redo(nodes, links);
        if (snapshot != null)
        {
            RestoreSnapshot(snapshot);
            Notification.ShowInfo("Redo");
        }
    }

    private void RestoreSnapshot(PipelineSnapshot snapshot)
    {
        // Clear current state
        _diagram.Nodes.Clear();
        _diagram.Links.Clear();

        // Restore nodes
        foreach (var sn in snapshot.Nodes)
        {
            var node = new ConnectorNode(new Point(sn.X, sn.Y))
            {
                NodeId = sn.NodeId,
                ConnectorType = sn.ConnectorType,
                Label = sn.Label,
                IsSource = sn.IsSource,
                IsSink = sn.IsSink,
                SubPipelineId = sn.SubPipelineId,
                SubPipelineName = sn.SubPipelineName
            };
            foreach (var (key, value) in sn.Config)
            {
                node.Config[key] = value;
            }
            _diagram.Nodes.Add(node);
        }

        // Restore links
        foreach (var sl in snapshot.Links)
        {
            var sourceNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == sl.SourceNodeId);
            var targetNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == sl.TargetNodeId);
            if (sourceNode != null && targetNode != null)
            {
                var sourcePort = sourceNode.Ports.FirstOrDefault();
                var targetPort = targetNode.Ports.FirstOrDefault();
                if (sourcePort != null && targetPort != null)
                {
                    var link = new PipelineLink(sourcePort, targetPort)
                    {
                        ConnectionId = sl.ConnectionId,
                        InternalTopic = sl.InternalTopic
                    };
                    _diagram.Links.Add(link);
                }
            }
        }

        _selectedNode = null;
        _selectedConfigSchema = null;
        StateHasChanged();
    }

