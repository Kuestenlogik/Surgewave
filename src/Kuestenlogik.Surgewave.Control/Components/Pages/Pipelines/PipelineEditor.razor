    }

    private void CloseSearch()
    {
        _showSearch = false;
        _searchQuery = "";
        _searchResults.Clear();
        StateHasChanged();
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                CloseSearch();
                break;
            case "Enter":
                if (_searchResults.Count > 0)
                {
                    if (e.ShiftKey)
                    {
                        // Previous result
                        _searchResultIndex = (_searchResultIndex - 1 + _searchResults.Count) % _searchResults.Count;
                    }
                    else
                    {
                        // Next result
                        _searchResultIndex = (_searchResultIndex + 1) % _searchResults.Count;
                    }
                    FocusSearchResult();
                }
                break;
            default:
                // Update search results
                Task.Run(async () =>
                {
                    await Task.Delay(100); // Debounce
                    await InvokeAsync(() =>
                    {
                        UpdateSearchResults();
                        StateHasChanged();
                    });
                });
                break;
        }
    }

    private void UpdateSearchResults()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResults.Clear();
            return;
        }

        var query = _searchQuery.ToLowerInvariant();
        _searchResults = _diagram.Nodes.OfType<ConnectorNode>()
            .Where(n => (n.Label?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        n.ConnectorType.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                        n.DisplayName.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _searchResultIndex = 0;
        if (_searchResults.Count > 0)
        {
            FocusSearchResult();
        }
    }

    private void FocusSearchResult()
    {
        if (_searchResultIndex < 0 || _searchResultIndex >= _searchResults.Count) return;

        var node = _searchResults[_searchResultIndex];
        if (node.Position != null)
        {
            _diagram.SetPan(-node.Position.X + 300, -node.Position.Y + 200);
            _diagram.SelectModel(node, false);
            _selectedNode = node;
            _ = LoadConfigSchemaAsync(node.ConnectorType);
        }
        StateHasChanged();
    }

    // Validation
    private void ValidateAllNodes()
    {
        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
        {
            ValidateNode(node);
        }
        _diagram.Refresh();
    }

    private void ValidateNode(ConnectorNode node)
    {
        node.ValidationState = NodeValidationState.Valid;
        node.ValidationMessage = null;

        // Skip validation for disabled nodes
        if (node.IsDisabled) return;

        // Validate composite nodes
        if (node.IsComposite)
        {
            if (string.IsNullOrEmpty(node.SubPipelineId))
            {
                node.ValidationState = NodeValidationState.Error;
                node.ValidationMessage = "Sub-pipeline reference is missing";
                return;
            }

            // Check that referenced pipeline exists
            if (!_availablePipelines.Any(p => p.Id == node.SubPipelineId))
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Referenced pipeline may have been deleted";
                return;
            }
        }

        // Check for unconnected source (should have outgoing connections)
        if (node.IsSource)
        {
            var hasOutgoing = _diagram.Links.Any(l =>
                l.Source?.Model is ConnectorNode sourceNode && sourceNode.NodeId == node.NodeId);
            if (!hasOutgoing)
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Source node has no outgoing connections";
                return;
            }
        }

        // Check for unconnected sink (should have incoming connections)
        if (node.IsSink)
        {
            var hasIncoming = _diagram.Links.Any(l =>
                l.Target?.Model is ConnectorNode targetNode && targetNode.NodeId == node.NodeId);
            if (!hasIncoming)
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Sink node has no incoming connections";
                return;
            }
        }

        // Check for transform nodes (should have both incoming and outgoing)
        if (!node.IsSource && !node.IsSink)
        {
            var hasIncoming = _diagram.Links.Any(l =>
                l.Target?.Model is ConnectorNode targetNode && targetNode.NodeId == node.NodeId);
            var hasOutgoing = _diagram.Links.Any(l =>
                l.Source?.Model is ConnectorNode sourceNode && sourceNode.NodeId == node.NodeId);

            if (!hasIncoming && !hasOutgoing)
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Transform node is not connected";
            }
            else if (!hasIncoming)
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Transform node has no incoming connections";
            }
            else if (!hasOutgoing)
            {
                node.ValidationState = NodeValidationState.Warning;
                node.ValidationMessage = "Transform node has no outgoing connections";
            }
        }

        // Check for required config fields
        var requiredFields = GetRequiredConfigFields(node);
        foreach (var field in requiredFields)
        {
            if (!node.Config.ContainsKey(field) || string.IsNullOrWhiteSpace(node.Config[field]))
            {
                node.ValidationState = NodeValidationState.Error;
                node.ValidationMessage = $"Required field '{field}' is not set";
                return;
            }
        }
    }

    private IEnumerable<string> GetRequiredConfigFields(ConnectorNode node)
    {
        // Get required fields from the schema if available
        var connectorType = _connectorTypes.FirstOrDefault(t => t.Type == node.ConnectorType);
        // For now, return empty - actual implementation would check the schema
        return [];
    }

