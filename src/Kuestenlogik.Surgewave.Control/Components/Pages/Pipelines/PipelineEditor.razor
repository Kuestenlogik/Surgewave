@page "/pipelines/new"
@page "/pipelines/{Id}/edit"
@rendermode InteractiveServer
@using Blazor.Diagrams
@using Blazor.Diagrams.Options
@using Blazor.Diagrams.Core.PathGenerators
@using Blazor.Diagrams.Core.Routers
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models
@using Kuestenlogik.Surgewave.Control.Components.Pipeline
@using Kuestenlogik.Surgewave.Control.Models.Pipeline
@using Kuestenlogik.Surgewave.Control.Models.Collaboration
@using Kuestenlogik.Surgewave.Control.Services
@using Kuestenlogik.Surgewave.Control.Services.Collaboration
@using Microsoft.AspNetCore.SignalR.Client
@inject IPipelineApiClient ApiClient
@inject IConnectorRegistryService ConnectorRegistry
@inject NavigationManager Navigation
@inject NotificationState Notification
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject IChatApiClient ChatApi
@inject CollaborationStateService CollaborationState
@implements IAsyncDisposable

<PageTitle>@(_isNew ? "New Pipeline" : _pipelineName) - Surgewave Control</PageTitle>

<div @ref="_keyboardTarget" tabindex="0" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventKeyDefault"
     class="pipeline-editor-container" @onfocus="OnContainerFocus">

    @* Header Bar - Fixed at top *@
    <MudPaper Elevation="2" Class="pa-3 pipeline-header">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_pipelineName" Label="Pipeline Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Required="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_pipelineDescription" Label="Description" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center justify-end gap-2">
                @if (_isDirty)
                {
                    <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning" Variant="Variant.Text">
                        Unsaved changes
                    </MudChip>
                }
                else if (_lastSaveTime.HasValue)
                {
                    <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Success" Variant="Variant.Text">
                        Saved @_lastSaveTime.Value.ToString("HH:mm:ss")
                    </MudChip>
                }
                @if (!_isNew)
                {
                    <MudToggleIconButton Toggled="_collaborationEnabled"
                                         Icon="@Icons.Material.Filled.PeopleOutline"
                                         ToggledIcon="@Icons.Material.Filled.People"
                                         ToggledColor="Color.Primary"
                                         Size="MudBlazor.Size.Small"
                                         ToggledChanged="OnCollaborationToggled" />
                    @if (_collaborationEnabled && _collabUsers.Count > 0)
                    {
                        <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Info" Variant="Variant.Text">
                            @_collabUsers.Count online
                        </MudChip>
                    }
                }
                <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
                <AuthorizeView Policy="@SurgewavePolicies.PipelinesManage">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync"
                               Disabled="@_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Save
                    </MudButton>
                    @if (!_isNew)
                    {
                        <MudButton Variant="Variant.Outlined" Color="@(_validationIssues.Count > 0 ? Color.Warning : Color.Default)"
                                   OnClick="ValidateAsync" Disabled="@_validating"
                                   StartIcon="@Icons.Material.Filled.FactCheck">
                            @if (_validating)
                            {
                                <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            Validate
                            @if (_validationIssues.Count > 0)
                            {
                                <MudChip T="string" Size="MudBlazor.Size.Small" Color="@(_validationErrors > 0 ? Color.Error : Color.Warning)" Class="ml-1">
                                    @_validationIssues.Count
                                </MudChip>
                            }
                        </MudButton>
                    }
                    @if (!_isNew && _pipeline?.Status == PipelineStatus.Running && _isDirty)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="AnalyzeAndHotDeployAsync"
                                   StartIcon="@Icons.Material.Filled.FlashOn" Disabled="@_saving">
                            Hot Deploy
                        </MudButton>
                    }
                    @if (!_isNew && _pipeline?.Status != PipelineStatus.Running)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveAndStartAsync"
                                   StartIcon="@Icons.Material.Filled.PlayArrow" Disabled="@_saving">
                            Save & Start
                        </MudButton>
                    }
                </AuthorizeView>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_breadcrumb.Count > 0)
    {
        <MudBreadcrumbs Items="@GetBreadcrumbItems()" Class="pa-0 my-1">
            <ItemTemplate Context="item">
                <MudLink OnClick="@(() => NavigateBreadcrumb(item.Href ?? ""))">
                    <MudIcon Icon="@(item.Icon ?? Icons.Material.Filled.AccountTree)" Size="MudBlazor.Size.Small" Class="mr-1" />
                    @item.Text
                </MudLink>
            </ItemTemplate>
        </MudBreadcrumbs>
    }

    @if (_pendingConnector != null)
    {
        <MudAlert Severity="Severity.Info" Class="my-2">
            Click on the canvas to place: <strong>@_pendingConnector.Name</strong>
            <MudButton Variant="Variant.Text" Size="MudBlazor.Size.Small" OnClick="ClearPendingConnector" Class="ml-2">
                Cancel
            </MudButton>
        </MudAlert>
    }

    @* Main Content Area - Flexbox layout *@
    <div class="pipeline-main-content">
        @* Left Panel - Connector Palette / Parameters *@
        <div class="pipeline-panel pipeline-palette">
            <MudTabs @bind-ActivePanelIndex="_leftPanelTab" Rounded="true" PanelClass="pa-0">
                <MudTabPanel Text="Connectors" Icon="@Icons.Material.Filled.Extension">
                    <NodePalette ConnectorTypes="@_connectorTypes"
                                 OnConnectorSelected="OnConnectorSelectedFromPalette"
                                 OnConnectorDragStart="OnConnectorDragStarted"
                                 AvailablePipelines="@_availablePipelines"
                                 OnPipelineNodeSelected="OnSubPipelineSelectedFromPalette" />
                </MudTabPanel>
                <MudTabPanel Text="Parameters" Icon="@Icons.Material.Filled.Tune">
                    <ParameterPanel Parameters="_parameters"
                                    ParametersChanged="OnParametersChanged"
                                    Environments="_environments"
                                    EnvironmentsChanged="OnEnvironmentsChanged" />
                </MudTabPanel>
                <MudTabPanel Text="Schedule" Icon="@Icons.Material.Filled.Schedule">
                    <SchedulePanel Schedule="@_scheduleConfig"
                                   ScheduleChanged="OnScheduleChanged" />
                </MudTabPanel>
            </MudTabs>
        </div>

        @* Center - Canvas *@
        <div class="pipeline-canvas-container">
            <PipelineToolbar EditorState="_editorState"
                             HasSelection="@(_selectedNodes.Count > 0)"
                             SelectionCount="@_selectedNodes.Count"
                             ZoomLevel="@(_diagram?.Zoom ?? 1.0)"
                             SnapToGrid="@_snapToGrid"
                             UndoRequested="Undo"
                             RedoRequested="Redo"
                             CutRequested="Cut"
                             CopyRequested="Copy"
                             PasteRequested="Paste"
                             SelectAllRequested="SelectAll"
                             DeleteSelectedRequested="DeleteSelected"
                             ToggleDisabledRequested="ToggleSelectedNodesDisabled"
                             ZoomInRequested="ZoomIn"
                             ZoomOutRequested="ZoomOut"
                             FitToViewRequested="FitToView"
                             AutoLayoutRequested="AutoLayout"
                             AutoLayoutDirectionRequested="AutoLayoutWithDirection"
                             AlignHorizontalRequested="AlignHorizontal"
                             AlignVerticalRequested="AlignVertical"
                             DistributeHorizontalRequested="DistributeHorizontal"
                             DistributeVerticalRequested="DistributeVertical"
                             SnapToGridToggled="ToggleSnapToGrid"
                             HasGroupSelected="@HasGroupSelected()"
                             GroupSelectionRequested="GroupSelectedNodes"
                             UngroupSelectionRequested="UngroupSelectedNodes"
                             DebugMode="@_debugMode"
                             DebugModeToggled="ToggleDebugMode"
                             ResumeAllRequested="DebugResumeAll" />

            <div class="pipeline-canvas">
                <PipelineDiagramCanvas Diagram="@_diagram"
                                       PendingConnector="@_pendingConnector"
                                       OnNodeAdded="OnNodeAdded"
                                       OnNodeSelected="OnNodeSelected"
                                       OnLinkCreated="OnLinkCreated"
                                       OnPendingConnectorCleared="ClearPendingConnector"
                                       OnConnectorDropped="OnConnectorDropped"
                                       OnContextMenuRequested="OnCanvasContextMenu" />

                <PipelineMiniMap Diagram="@_diagram"
                                 SelectedNode="@_selectedNode"
                                 OnNodeFocused="FocusNode" />

                @if (_showAlignmentGuides && (_horizontalGuides.Count > 0 || _verticalGuides.Count > 0))
                {
                    <AlignmentGuideOverlay HorizontalGuides="_horizontalGuides" VerticalGuides="_verticalGuides" />
                }

                @if (_collaborationEnabled)
                {
                    <CollaborationOverlay Users="@_collabUsers"
                                           NodeLocks="@_collabNodeLocks"
                                           Comments="@_collabComments"
                                           PendingApprovals="@_collabApprovals.Count(a => a.Status == ApprovalStatus.Pending)" />
                }
            </div>
        </div>

        @* Right Panel - Config & Details *@
        <div class="pipeline-panel pipeline-config">
            <NodeConfigPanel SelectedNode="@_selectedNode"
                             ConfigSchema="@_selectedConfigSchema"
                             OnNodeConfigChanged="OnNodeConfigChanged"
                             OnNodeDeleted="OnNodeDeleted"
                             OpenSubPipeline="OpenSubPipelineEditor"
                             ConfigurePortMapping="OpenPortMappingDialog"
                             AvailableWorkers="@GetAvailableWorkersForSelectedNode()" />

            @if (!_isNew)
            {
                <DebugPanel DebugMode="@_debugMode"
                            DebugModeToggled="@(async (bool v) => await ToggleDebugMode())"
                            DebugState="@_debugState"
                            RemoveBreakpoint="@(async (string nodeId) => { if (Id != null) { await ApiClient.RemoveBreakpointAsync(Id, nodeId); } })"
                            StepNode="@(async (string nodeId) => await DebugStepNode(nodeId))"
                            ResumeNodeRequested="@(async (string nodeId) => await DebugResumeNode(nodeId))"
                            ResumeAll="DebugResumeAll" />

                <LiveDataPreviewPanel PipelineId="@Id"
                                      SelectedNodeId="@_selectedNode?.NodeId"
                                      OnLineageClicked="OnLineagePathReceived" />

                <VersionHistoryPanel PipelineId="@Id"
                                     OnVersionRestored="OnVersionRestored" />

                @if (_collaborationEnabled)
                {
                    <CommentPanel Comments="@_collabComments"
                                  FilterNodeId="@_commentFilterNodeId"
                                  UserName="@_collabUserName"
                                  OnAddComment="OnAddComment"
                                  OnResolveComment="OnResolveComment"
                                  OnNodeFilterCleared="() => { _commentFilterNodeId = null; StateHasChanged(); }" />

                    <ApprovalPanel Approvals="@_collabApprovals"
                                   UserName="@_collabUserName"
                                   OnRequestApproval="OnRequestApproval"
                                   OnReviewApproval="OnReviewApproval" />
                }
            }
        </div>
    </div>
</div>

@if (_hasChatEndpoint && !_isNew)
{
    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat"
            Style="position: fixed; bottom: 24px; right: 24px; z-index: 1100;"
            OnClick="ToggleChatDrawer" />
    <ChatDrawer PipelineId="@(Id ?? "")" IsOpen="_chatDrawerOpen" IsOpenChanged="OnChatDrawerChanged" />
}

<style>
    .pipeline-editor-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 100px);
        outline: none;
        overflow: hidden;
    }

    .pipeline-header {
        flex-shrink: 0;
        margin-bottom: 8px;
    }

    .pipeline-main-content {
        display: flex;
        flex: 1;
        gap: 16px;
        min-height: 0;
        overflow: hidden;
    }

    .pipeline-panel {
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
    }

    .pipeline-palette {
        width: 250px;
        flex-shrink: 0;
    }

    .pipeline-palette > :deep(.mud-paper) {
        height: 100%;
        overflow-y: auto;
    }

    .pipeline-canvas-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        min-height: 0;
        overflow: hidden;
    }

    .pipeline-canvas {
        flex: 1;
        position: relative;
        min-height: 0;
        overflow: hidden;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 4px;
    }

    .pipeline-config {
        width: 300px;
        flex-shrink: 0;
        overflow-y: auto;
    }

    .pipeline-config > :deep(.mud-paper) {
        margin-bottom: 16px;
    }
</style>

@* Node Search Overlay *@
@if (_showSearch)
{
    <div class="search-overlay">
        <MudPaper Elevation="4" Class="search-box pa-2">
            <MudTextField @bind-Value="_searchQuery" Label="Search nodes..." Variant="Variant.Outlined"
                          Margin="Margin.Dense" Immediate="true" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          @onkeydown="HandleSearchKeyDown"
                          @ref="_searchField" />
            @if (_searchResults.Count > 0)
            {
                <MudText Typo="Typo.caption" Class="mt-1">
                    @(_searchResultIndex + 1) / @_searchResults.Count - Enter: next, Shift+Enter: previous
                </MudText>
            }
            else if (!string.IsNullOrEmpty(_searchQuery))
            {
                <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                    No nodes found
                </MudText>
            }
        </MudPaper>
    </div>
}

@* Context Menu *@
@if (_showContextMenu)
{
    <div class="context-menu-backdrop" @onclick="CloseContextMenu" @oncontextmenu="CloseContextMenu" @oncontextmenu:preventDefault></div>
    <MudPaper Class="context-menu" Elevation="8" Style="@($"left: {_contextMenuX}px; top: {_contextMenuY}px;")">
        <MudList T="string" Dense="true" Class="pa-0">
            @if (_contextMenuNode != null)
            {
                @if (_contextMenuNode.IsComposite)
                {
                    <MudListItem Icon="@Icons.Material.Filled.OpenInNew" OnClick="@(() => { CloseContextMenu(); OpenSubPipelineEditor(_contextMenuNode.SubPipelineId); })">
                        Open Sub-Pipeline
                    </MudListItem>
                    <MudDivider />
                }
                <MudListItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => ContextMenuEditNode())">
                    Edit Configuration
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => ContextMenuDuplicateNode())">
                    Duplicate
                </MudListItem>
                <MudDivider />
                <MudListItem Icon="@Icons.Material.Filled.ContentCut" OnClick="@(() => ContextMenuCutNode())">
                    Cut
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => ContextMenuCopyNode())">
                    Copy
                </MudListItem>
                <MudDivider />
                <MudListItem Icon="@(_contextMenuNode.IsDisabled ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                             OnClick="@(() => ContextMenuToggleDisabled())">
                    @(_contextMenuNode.IsDisabled ? "Enable" : "Disable")
                </MudListItem>
                @if (_debugMode)
                {
                    <MudDivider />
                    <MudListItem Icon="@Icons.Material.Filled.BugReport"
                                 IconColor="@(_contextMenuNode.HasBreakpoint ? Color.Error : Color.Default)"
                                 OnClick="@(async () => { await ToggleBreakpoint(_contextMenuNode); CloseContextMenu(); })">
                        @(_contextMenuNode.HasBreakpoint ? "Remove Breakpoint" : "Toggle Breakpoint")
                    </MudListItem>
                }
                <MudListItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => ContextMenuDeleteNode())">
                    Delete
                </MudListItem>
            }
            else
            {
                <MudListItem Icon="@Icons.Material.Filled.ContentPaste" Disabled="@(!_editorState.HasClipboard)" OnClick="@(() => ContextMenuPaste())">
                    Paste
                </MudListItem>
                <MudDivider />
                <MudListItem Icon="@Icons.Material.Filled.SelectAll" OnClick="@(() => { SelectAll(); CloseContextMenu(); })">
                    Select All
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.AutoAwesomeMosaic" OnClick="@(() => { AutoLayoutWithDirection(LayoutDirection.TopToBottom); CloseContextMenu(); })">
                    Auto Layout (TB)
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ViewStream" OnClick="@(() => { AutoLayoutWithDirection(LayoutDirection.LeftToRight); CloseContextMenu(); })">
                    Auto Layout (LR)
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.FitScreen" OnClick="@(() => { FitToView(); CloseContextMenu(); })">
                    Fit to View
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}

<style>
    .search-overlay {
        position: fixed;
        top: 80px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1200;
    }
    .search-box {
        min-width: 350px;
    }
    .context-menu-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1299;
    }
    .context-menu {
        position: fixed;
        z-index: 1300;
        min-width: 180px;
    }
</style>

@code {
    [Parameter]
    public string? Id { get; set; }

    private bool _isNew => string.IsNullOrEmpty(Id);
    private PipelineDefinition? _pipeline;
    private string _pipelineName = "New Pipeline";
    private string _pipelineDescription = "";
    private bool _saving = false;
    private bool _validating = false;
    private List<PipelineValidationIssueDto> _validationIssues = [];
    private int _validationErrors => _validationIssues.Count(i => i.Severity == "Error");

    private BlazorDiagram _diagram = null!;
    private ConnectorNode? _selectedNode;
    private ConnectorConfigSchema? _selectedConfigSchema;
    private List<ConnectorTypeInfo> _connectorTypes = [];
    private ConnectorTypeInfo? _pendingConnector;
    private ConnectorTypeInfo? _draggingConnector;

    private readonly PipelineEditorState _editorState = new();
    private readonly List<ConnectorNode> _selectedNodes = [];
    private List<PipelineSummary> _availablePipelines = [];
    private string? _pendingSubPipelineId;
    private string? _pendingSubPipelineName;

    // Breadcrumb navigation for sub-pipelines
    private readonly Stack<BreadcrumbEntry> _breadcrumb = new();

    // Keyboard handling
    private ElementReference _keyboardTarget;
    private bool _preventKeyDefault;

    // Context menu
    private bool _showContextMenu;
    private double _contextMenuX;
    private double _contextMenuY;
    private ConnectorNode? _contextMenuNode;

    // Snap to grid
    private bool _snapToGrid = true;
    private const double GridSize = 20.0;

    // Node search
    private bool _showSearch;
    private string _searchQuery = "";
    private List<ConnectorNode> _searchResults = [];
    private int _searchResultIndex;
    private MudTextField<string>? _searchField;

    // Auto-save
    private System.Threading.Timer? _autoSaveTimer;
    private bool _isDirty;
    private DateTime? _lastSaveTime;
    private const int AutoSaveIntervalMs = 30000; // 30 seconds

    // Metrics polling (Feature 4)
    private System.Threading.Timer? _metricsTimer;
    private const int MetricsIntervalMs = 3000;
    private bool _pipelineIsRunning;

    // Debug mode (Feature 1)
    private bool _debugMode;
    private DebugState? _debugState;
    private System.Threading.Timer? _debugTimer;
    private const int DebugPollIntervalMs = 1000;

    // Pipeline parameters (Feature 3)
    private List<PipelineParameter> _parameters = [];
    private List<PipelineEnvironment> _environments = [];
    private int _leftPanelTab;

    // Pipeline schedule
    private ScheduleConfig? _scheduleConfig;

    // Data provenance / lineage highlighting
    private readonly HashSet<string> _highlightedLineageNodes = [];
    private CancellationTokenSource? _lineageHighlightCts;

    // Alignment guides
    private bool _showAlignmentGuides = true;
    private readonly List<AlignmentGuide> _horizontalGuides = [];
    private readonly List<AlignmentGuide> _verticalGuides = [];
    private const double AlignmentSnapThreshold = 10.0;

    // Chat drawer
    private bool _chatDrawerOpen;
    private bool _hasChatEndpoint;

    // Collaboration (multi-user editing via SignalR)
    private bool _collaborationEnabled;
    private HubConnection? _hubConnection;
    private string _collabUserName = $"User-{System.Security.Cryptography.RandomNumberGenerator.GetInt32(1000, 9999)}";
    private List<PresenceInfo> _collabUsers = [];
    private List<PipelineComment> _collabComments = [];
    private List<ApprovalRequest> _collabApprovals = [];
    private Dictionary<string, string> _collabNodeLocks = [];
    private string? _commentFilterNodeId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _keyboardTarget.FocusAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        InitializeDiagram();
        _editorState.StateChanged += StateHasChanged;

        // Load connector types
        try
        {
            var types = await ConnectorRegistry.GetConnectorTypesAsync();
            _connectorTypes = types.ToList();

            // Add built-in Streams processing nodes
            _connectorTypes.AddRange(GetBuiltInStreamsNodes());
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to load connector types: {ex.Message}");
        }

        // Load available pipelines for sub-pipeline palette
        try
        {
            var allPipelines = await ApiClient.ListPipelinesAsync();
            _availablePipelines = allPipelines
                .Where(p => p.Id != Id) // Exclude current pipeline to prevent self-reference
                .Select(p => new PipelineSummary(p.Id, p.Name, p.Description, p.Nodes.Count))
                .ToList();
        }
        catch
        {
            // Non-critical — sub-pipeline palette just won't show pipelines
        }

        // Load existing pipeline if editing
        if (!_isNew)
        {
            await LoadPipelineAsync();
        }

        // Start auto-save timer
        _autoSaveTimer = new System.Threading.Timer(
            async _ => await AutoSaveAsync(),
            null,
            AutoSaveIntervalMs,
            AutoSaveIntervalMs);
    }

    private void InitializeDiagram()
    {
        var options = new BlazorDiagramOptions
        {
            AllowMultiSelection = true
        };
        options.Zoom.Enabled = true;
        options.Zoom.Minimum = 0.5;
        options.Zoom.Maximum = 2;
        options.Links.DefaultRouter = new NormalRouter();
        options.Links.DefaultPathGenerator = new SmoothPathGenerator();

        _diagram = new BlazorDiagram(options);

        // Register custom models
        _diagram.RegisterComponent<ConnectorNode, ConnectorNodeWidget>();
        _diagram.RegisterComponent<PipelineLink, PipelineLinkWidget>();
        _diagram.RegisterComponent<NodeGroup, NodeGroupWidget>();

        // Track selection changes
        _diagram.SelectionChanged += OnSelectionChanged;

        // Track node movements for alignment guides
        _diagram.Nodes.Added += RegisterNodeMovementEvents;
    }

    private void RegisterNodeMovementEvents(Blazor.Diagrams.Core.Models.NodeModel node)
    {
        node.Moving += OnNodeMoving;
        node.Moved += OnNodeMoved;
    }

    private void OnNodeMoving(Blazor.Diagrams.Core.Models.Base.MovableModel model)
    {
        if (!_showAlignmentGuides || model is not ConnectorNode movingNode) return;

        _horizontalGuides.Clear();
        _verticalGuides.Clear();

        var movingX = movingNode.Position?.X ?? 0;
        var movingY = movingNode.Position?.Y ?? 0;

        foreach (var otherNode in _diagram.Nodes.OfType<ConnectorNode>())
        {
            if (otherNode.NodeId == movingNode.NodeId) continue;

            var otherX = otherNode.Position?.X ?? 0;
            var otherY = otherNode.Position?.Y ?? 0;

            // Check horizontal alignment (same Y)
            if (Math.Abs(movingY - otherY) < AlignmentSnapThreshold)
            {
                _horizontalGuides.Add(AlignmentGuide.Horizontal(otherY, otherNode.NodeId));
            }

            // Check vertical alignment (same X)
            if (Math.Abs(movingX - otherX) < AlignmentSnapThreshold)
            {
                _verticalGuides.Add(AlignmentGuide.Vertical(otherX, otherNode.NodeId));
            }
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnNodeMoved(Blazor.Diagrams.Core.Models.Base.MovableModel model)
    {
        // Clear guides when movement stops
        _horizontalGuides.Clear();
        _verticalGuides.Clear();
        InvokeAsync(StateHasChanged);
    }

    private void OnSelectionChanged(Blazor.Diagrams.Core.Models.Base.SelectableModel? model)
    {
        _selectedNodes.Clear();
        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
        {
            if (node.Selected)
            {
                _selectedNodes.Add(node);
            }
        }
        StateHasChanged();
    }

    private async Task LoadPipelineAsync()
    {
        try
        {
            _pipeline = await ApiClient.GetPipelineAsync(Id!);
            if (_pipeline == null)
            {
                Notification.ShowError("Pipeline not found");
                Navigation.NavigateTo("/pipelines");
                return;
            }

            _pipelineName = _pipeline.Name;
            _pipelineDescription = _pipeline.Description ?? "";
            _parameters = _pipeline.Parameters.ToList();
            _environments = _pipeline.Environments.ToList();
            _scheduleConfig = _pipeline.Schedule;

            // Restore nodes
            foreach (var node in _pipeline.Nodes)
            {
                var isSource = node.IsComposite ? false : DetermineIsSource(node.ConnectorType);
                var isSink = node.IsComposite ? false : DetermineIsSink(node.ConnectorType);
                var isTransform = !isSource && !isSink && !node.IsComposite;

                var connectorNode = new ConnectorNode(new Point(node.X, node.Y))
                {
                    NodeId = node.Id,
                    ConnectorType = node.ConnectorType,
                    Label = node.Label,
                    IsSource = isSource,
                    IsSink = isSink,
                    SubPipelineId = node.SubPipelineId,
                    HasErrorPort = isTransform
                };

                connectorNode.RetryPolicy = node.RetryPolicy;
                connectorNode.PortMappingsJson = node.PortMappingsJson;

                // Restore port labels from mapping
                if (!string.IsNullOrEmpty(node.PortMappingsJson))
                {
                    try
                    {
                        var mapping = System.Text.Json.JsonSerializer.Deserialize<SubPipelinePortMappingModel>(node.PortMappingsJson);
                        if (mapping != null)
                        {
                            connectorNode.InputPortLabels = mapping.InputMappings
                                .Select(m => m.SubNodeLabel ?? m.SubPipelineNodeId).ToList();
                            connectorNode.OutputPortLabels = mapping.OutputMappings
                                .Select(m => m.SubNodeLabel ?? m.SubPipelineNodeId).ToList();
                        }
                    }
                    catch { /* ignore parse errors */ }
                }

                foreach (var (key, value) in node.Config)
                {
                    connectorNode.Config[key] = value;
                }

                // Add ports: composite nodes get both in/out
                if (node.IsComposite)
                {
                    connectorNode.AddPort(PortAlignment.Left);
                    connectorNode.AddPort(PortAlignment.Right);
                }
                else if (isSource)
                {
                    connectorNode.AddPort(PortAlignment.Right);
                }
                else if (isSink)
                {
                    connectorNode.AddPort(PortAlignment.Left);
                }
                else
                {
                    connectorNode.AddPort(PortAlignment.Left);
                    connectorNode.AddPort(PortAlignment.Right);
                    connectorNode.AddPort(PortAlignment.Bottom); // Error port
                }

                _diagram.Nodes.Add(connectorNode);
            }

            // Restore connections
            foreach (var connection in _pipeline.Connections)
            {
                var sourceNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == connection.SourceNodeId);
                var targetNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == connection.TargetNodeId);

                if (sourceNode != null && targetNode != null)
                {
                    var isErrorConnection = connection.Type == "error";

                    // For error connections, use the Bottom port as source
                    var sourcePort = isErrorConnection
                        ? sourceNode.Ports.FirstOrDefault(p => p.Alignment == PortAlignment.Bottom) ?? sourceNode.Ports.FirstOrDefault()
                        : sourceNode.Ports.FirstOrDefault(p => p.Alignment != PortAlignment.Bottom) ?? sourceNode.Ports.FirstOrDefault();
                    var targetPort = targetNode.Ports.FirstOrDefault(p => p.Alignment == PortAlignment.Left) ?? targetNode.Ports.FirstOrDefault();

                    if (sourcePort != null && targetPort != null)
                    {
                        var link = new PipelineLink(sourcePort, targetPort)
                        {
                            ConnectionId = connection.Id,
                            InternalTopic = connection.InternalTopic,
                            IsErrorLink = isErrorConnection
                        };
                        _diagram.Links.Add(link);
                    }
                }
            }

            // Save initial state for undo
            SaveStateForUndo("Load pipeline");

            // Start metrics polling if pipeline is running
            if (_pipeline.Status == PipelineStatus.Running)
            {
                _pipelineIsRunning = true;
                StartMetricsTimer();
            }

            // Detect ChatEndpoint nodes for chat FAB
            _hasChatEndpoint = _pipeline.Nodes.Any(n =>
                n.ConnectorType.Contains("ChatEndpoint", StringComparison.OrdinalIgnoreCase));
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to load pipeline: {ex.Message}");
            Navigation.NavigateTo("/pipelines");
        }
    }

    private bool DetermineIsSource(string connectorType)
    {
        // Built-in Streams nodes are never Source/Sink
        if (connectorType == ConnectorNode.SqlTransformType ||
            connectorType == ConnectorNode.ExceptionHandlerType)
            return false;

        var type = _connectorTypes.FirstOrDefault(t => t.Type == connectorType);
        return type?.IsSource ?? connectorType.Contains("Source", StringComparison.OrdinalIgnoreCase);
    }

    private bool DetermineIsSink(string connectorType)
    {
        // Built-in Streams nodes are never Source/Sink
        if (connectorType == ConnectorNode.SqlTransformType ||
            connectorType == ConnectorNode.ExceptionHandlerType)
            return false;

        var type = _connectorTypes.FirstOrDefault(t => t.Type == connectorType);
        return type?.IsSink ?? connectorType.Contains("Sink", StringComparison.OrdinalIgnoreCase);
    }

