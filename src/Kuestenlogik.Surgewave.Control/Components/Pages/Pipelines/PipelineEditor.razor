    private async Task OnCollaborationToggled(bool enabled)
    {
        _collaborationEnabled = enabled;
        if (enabled && !_isNew && Id != null)
        {
            await StartCollaborationAsync();
        }
        else if (!enabled)
        {
            await StopCollaborationAsync();
        }
    }

    private async Task StartCollaborationAsync()
    {
        if (_hubConnection != null) return;

        var hubUrl = Navigation.ToAbsoluteUri("/hubs/collaboration");
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        // Register event handlers
        _hubConnection.On<PresenceInfo>("UserJoined", user =>
        {
            if (user.ConnectionId != _hubConnection.ConnectionId)
            {
                _collabUsers.RemoveAll(u => u.ConnectionId == user.ConnectionId);
                _collabUsers.Add(user);
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string>("UserLeft", connectionId =>
        {
            _collabUsers.RemoveAll(u => u.ConnectionId == connectionId);
            // Remove locks held by this user
            var lockedNodes = _collabNodeLocks.Where(kv => kv.Value == connectionId).Select(kv => kv.Key).ToList();
            foreach (var nodeId in lockedNodes) _collabNodeLocks.Remove(nodeId);
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<IReadOnlyList<PresenceInfo>>("PresenceSnapshot", users =>
        {
            _collabUsers = users.Where(u => u.ConnectionId != _hubConnection.ConnectionId).ToList();
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string, double, double>("CursorMoved", (connectionId, x, y) =>
        {
            var user = _collabUsers.FirstOrDefault(u => u.ConnectionId == connectionId);
            if (user != null)
            {
                user.CursorX = x;
                user.CursorY = y;
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string, string, double, double>("NodeMoved", (connectionId, nodeId, x, y) =>
        {
            var node = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == nodeId);
            if (node != null)
            {
                node.SetPosition(x, y);
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string, string>("NodeRemoved", (connectionId, nodeId) =>
        {
            var node = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == nodeId);
            if (node != null)
            {
                _diagram.Nodes.Remove(node);
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string, string, string>("NodeConfigChanged", (connectionId, nodeId, configJson) =>
        {
            var node = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == nodeId);
            if (node != null)
            {
                try
                {
                    var config = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(configJson);
                    if (config != null)
                    {
                        node.Config.Clear();
                        foreach (var (key, value) in config)
                        {
                            node.Config[key] = value;
                        }
                    }
                }
                catch { /* ignore deserialization errors */ }
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string, string>("NodeLocked", (connectionId, nodeId) =>
        {
            _collabNodeLocks[nodeId] = connectionId;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string, string>("NodeUnlocked", (connectionId, nodeId) =>
        {
            _collabNodeLocks.Remove(nodeId);
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string, string>("LockDenied", (nodeId, owner) =>
        {
            var ownerUser = _collabUsers.FirstOrDefault(u => u.ConnectionId == owner);
            Notification.ShowWarning($"Node is being edited by {ownerUser?.UserName ?? "another user"}");
        });

        _hubConnection.On<IReadOnlyDictionary<string, string>>("NodeLocksSnapshot", locks =>
        {
            _collabNodeLocks = new Dictionary<string, string>(locks);
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<PipelineComment>("CommentAdded", comment =>
        {
            _collabComments.Add(comment);
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string>("CommentResolved", commentId =>
        {
            var comment = _collabComments.FirstOrDefault(c => c.Id == commentId);
            if (comment != null) comment.Resolved = !comment.Resolved;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<IReadOnlyList<PipelineComment>>("CommentsSnapshot", comments =>
        {
            _collabComments = comments.ToList();
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ApprovalRequest>("ApprovalRequested", approval =>
        {
            _collabApprovals.Add(approval);
            Notification.ShowInfo($"{approval.RequestedBy} requested approval: {approval.Message}");
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string, ApprovalStatus, string>("ApprovalReviewed", (approvalId, status, reviewer) =>
        {
            var approval = _collabApprovals.FirstOrDefault(a => a.Id == approvalId);
            if (approval != null)
            {
                approval.Status = status;
                approval.ReviewedBy = reviewer;
                approval.ReviewedAt = DateTimeOffset.UtcNow;
            }
            Notification.ShowInfo($"{reviewer} {status.ToString().ToLowerInvariant()} the change");
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<IReadOnlyList<ApprovalRequest>>("ApprovalsSnapshot", approvals =>
        {
            _collabApprovals = approvals.ToList();
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinPipeline", Id, _collabUserName);
            Notification.ShowSuccess("Collaboration mode enabled");
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to connect to collaboration hub: {ex.Message}");
            _collaborationEnabled = false;
        }
    }

    private async Task StopCollaborationAsync()
    {
        if (_hubConnection != null && Id != null)
        {
            try
            {
                await _hubConnection.SendAsync("LeavePipeline", Id);
                await _hubConnection.DisposeAsync();
            }
            catch { /* ignore */ }
            _hubConnection = null;
        }
        _collabUsers.Clear();
        _collabComments.Clear();
        _collabApprovals.Clear();
        _collabNodeLocks.Clear();
        StateHasChanged();
    }

