    private void StartMetricsTimer()
    {
        _metricsTimer?.Dispose();
        _metricsTimer = new System.Threading.Timer(
            async _ => await RefreshMetricsAsync(),
            null,
            0,
            MetricsIntervalMs);
    }

    private void StopMetricsTimer()
    {
        _metricsTimer?.Dispose();
        _metricsTimer = null;
    }

    private async Task RefreshMetricsAsync()
    {
        if (_isNew || Id is null) return;
        try
        {
            await InvokeAsync(async () =>
            {
                var status = await ApiClient.GetPipelineStatusAsync(Id);
                var wasRunning = _pipelineIsRunning;
                _pipelineIsRunning = status?.Status == PipelineStatus.Running;

                if (_pipelineIsRunning)
                {
                    var metrics = await ApiClient.GetPipelineMetricsAsync(Id);
                    if (metrics != null)
                    {
                        ApplyMetricsToNodes(metrics);
                        ApplyMetricsToLinks(metrics);
                    }

                    // Update node running state
                    foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
                    {
                        var nodeStatus = status?.Nodes.FirstOrDefault(n => n.NodeId == node.NodeId);
                        node.IsRunning = nodeStatus?.State == "Running" || _pipelineIsRunning;
                    }

                    if (!wasRunning)
                        _diagram.Refresh();
                }
                else if (wasRunning)
                {
                    // Pipeline stopped — clear metrics
                    foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
                    {
                        node.IsRunning = false;
                        node.RecordsPerSec = 0;
                        node.TotalErrors = 0;
                        node.P99LatencyMs = 0;
                    }
                    foreach (var link in _diagram.Links.OfType<PipelineLink>())
                    {
                        link.QueueDepth = 0;
                        link.BackPressureLevel = Models.Pipeline.BackPressureLevel.Normal;
                    }
                    StopMetricsTimer();
                }

                StateHasChanged();
            });
        }
        catch
        {
            // Silently ignore metrics fetch errors
        }
    }

    private void ApplyMetricsToNodes(PipelineMetricsResponse metrics)
    {
        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
        {
            if (metrics.Nodes.TryGetValue(node.NodeId, out var nm))
            {
                node.RecordsPerSec = nm.RecordsPerSec > 0 ? nm.RecordsPerSec : metrics.RecordsPerSec / Math.Max(metrics.Nodes.Count, 1);
                node.TotalErrors = nm.Errors;
                node.P99LatencyMs = nm.P99LatencyMs;
            }
        }
        _diagram.Refresh();
    }

    private void ApplyMetricsToLinks(PipelineMetricsResponse metrics)
    {
        foreach (var link in _diagram.Links.OfType<PipelineLink>())
        {
            if (metrics.Connections.TryGetValue(link.ConnectionId, out var cm))
            {
                link.QueueDepth = cm.QueueDepth;
                link.Throughput = cm.ThroughputPerSec;
                link.BackPressureLevel = cm.Level;
            }
        }
    }

