    private async Task OnConnectorDropped((ConnectorTypeInfo Connector, double X, double Y) args)
    {
        if (_draggingConnector == null) return;

        var x = _snapToGrid ? SnapToGridValue(args.X) : args.X;
        var y = _snapToGrid ? SnapToGridValue(args.Y) : args.Y;
        var node = CreateNodeFromConnector(_draggingConnector, x, y);
        _diagram.Nodes.Add(node);
        await OnNodeAdded(node);
        _draggingConnector = null;
    }

    private ConnectorNode CreateNodeFromConnector(ConnectorTypeInfo connector, double x, double y)
    {
        if (_snapToGrid)
        {
            x = SnapToGridValue(x);
            y = SnapToGridValue(y);
        }

        var isTransform = !connector.IsSource && !connector.IsSink;

        var node = new ConnectorNode(new Point(x, y))
        {
            NodeId = Guid.NewGuid().ToString("N"),
            ConnectorType = connector.Type,
            Label = connector.Name,
            IsSource = connector.IsSource,
            IsSink = connector.IsSink,
            HasErrorPort = isTransform
        };

        // Add ports based on node type
        if (connector.IsSource)
        {
            node.AddPort(PortAlignment.Right);
        }
        else if (connector.IsSink)
        {
            node.AddPort(PortAlignment.Left);
        }
        else
        {
            node.AddPort(PortAlignment.Left);
            node.AddPort(PortAlignment.Right);
            // Error port at bottom for transform/logic nodes
            node.AddPort(PortAlignment.Bottom);
        }

        return node;
    }

