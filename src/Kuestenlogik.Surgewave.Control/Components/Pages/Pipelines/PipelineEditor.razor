    private void AutoLayoutWithDirection(LayoutDirection direction)
    {
        SaveStateForUndo("Auto layout");
        var nodes = _diagram.Nodes.OfType<ConnectorNode>().ToList();
        if (nodes.Count == 0) return;

        // Extract links
        var links = _diagram.Links.OfType<PipelineLink>()
            .Select(l => (
                SourceId: ((ConnectorNode?)l.Source?.Model)?.NodeId ?? "",
                TargetId: ((ConnectorNode?)l.Target?.Model)?.NodeId ?? ""
            ))
            .Where(l => !string.IsNullOrEmpty(l.SourceId) && !string.IsNullOrEmpty(l.TargetId))
            .ToList();

        // Extract groups
        var groups = _diagram.Groups.OfType<NodeGroup>()
            .Select(g => (
                GroupName: g.GroupName ?? "Group",
                NodeIds: (IReadOnlyList<string>)g.Children
                    .OfType<ConnectorNode>()
                    .Select(n => n.NodeId)
                    .ToList()
            ))
            .Where(g => g.NodeIds.Count > 0)
            .ToList();

        LayoutResult result;
        if (groups.Count > 0)
        {
            result = _layoutService.ComputeLayoutWithGroups(nodes, links, groups, direction);
        }
        else
        {
            result = _layoutService.ComputeLayout(nodes, links, direction);
        }

        // Apply positions
        foreach (var node in nodes)
        {
            if (result.Positions.TryGetValue(node.NodeId, out var pos))
            {
                var x = _snapToGrid ? SnapToGridValue(pos.X) : pos.X;
                var y = _snapToGrid ? SnapToGridValue(pos.Y) : pos.Y;
                node.SetPosition(x, y);
            }
        }

        _diagram.Refresh();
    }

    private void AlignHorizontal()
    {
        if (_selectedNodes.Count < 2) return;
        SaveStateForUndo("Align horizontal");
        var avgY = _selectedNodes.Average(n => n.Position?.Y ?? 0);
        foreach (var node in _selectedNodes)
        {
            node.SetPosition(node.Position?.X ?? 0, avgY);
        }
        _diagram.Refresh();
    }

    private void AlignVertical()
    {
        if (_selectedNodes.Count < 2) return;
        SaveStateForUndo("Align vertical");
        var avgX = _selectedNodes.Average(n => n.Position?.X ?? 0);
        foreach (var node in _selectedNodes)
        {
            node.SetPosition(avgX, node.Position?.Y ?? 0);
        }
        _diagram.Refresh();
    }

    private void DistributeHorizontal()
    {
        if (_selectedNodes.Count < 3) return;
        SaveStateForUndo("Distribute horizontal");
        var sorted = _selectedNodes.OrderBy(n => n.Position?.X ?? 0).ToList();
        var minX = sorted.First().Position?.X ?? 0;
        var maxX = sorted.Last().Position?.X ?? 0;
        var step = (maxX - minX) / (sorted.Count - 1);

        for (var i = 0; i < sorted.Count; i++)
        {
            sorted[i].SetPosition(minX + i * step, sorted[i].Position?.Y ?? 0);
        }
        _diagram.Refresh();
    }

    private void DistributeVertical()
    {
        if (_selectedNodes.Count < 3) return;
        SaveStateForUndo("Distribute vertical");
        var sorted = _selectedNodes.OrderBy(n => n.Position?.Y ?? 0).ToList();
        var minY = sorted.First().Position?.Y ?? 0;
        var maxY = sorted.Last().Position?.Y ?? 0;
        var step = (maxY - minY) / (sorted.Count - 1);

        for (var i = 0; i < sorted.Count; i++)
        {
            sorted[i].SetPosition(sorted[i].Position?.X ?? 0, minY + i * step);
        }
        _diagram.Refresh();
    }

