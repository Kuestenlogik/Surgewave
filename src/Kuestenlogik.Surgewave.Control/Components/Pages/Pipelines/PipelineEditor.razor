    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventKeyDefault = false;

        // Ctrl shortcuts
        if (e.CtrlKey && !e.ShiftKey && !e.AltKey)
        {
            switch (e.Key.ToLowerInvariant())
            {
                case "z":
                    _preventKeyDefault = true;
                    Undo();
                    break;
                case "y":
                    _preventKeyDefault = true;
                    Redo();
                    break;
                case "x":
                    _preventKeyDefault = true;
                    Cut();
                    break;
                case "c":
                    _preventKeyDefault = true;
                    Copy();
                    break;
                case "v":
                    _preventKeyDefault = true;
                    Paste();
                    break;
                case "a":
                    _preventKeyDefault = true;
                    SelectAll();
                    break;
                case "s":
                    _preventKeyDefault = true;
                    await SaveAsync();
                    break;
                case "f":
                    _preventKeyDefault = true;
                    await OpenSearch();
                    break;
                case "0":
                    _preventKeyDefault = true;
                    FitToView();
                    break;
                case "g":
                    _preventKeyDefault = true;
                    GroupSelectedNodes();
                    break;
            }
        }
        // Ctrl+Shift shortcuts
        else if (e.CtrlKey && e.ShiftKey && !e.AltKey)
        {
            switch (e.Key.ToLowerInvariant())
            {
                case "z":
                    _preventKeyDefault = true;
                    Redo();
                    break;
            }
        }
        // No modifier shortcuts
        else if (!e.CtrlKey && !e.ShiftKey && !e.AltKey)
        {
            switch (e.Key)
            {
                case "Delete":
                case "Backspace":
                    _preventKeyDefault = true;
                    DeleteSelected();
                    break;
                case "Escape":
                    _preventKeyDefault = true;
                    if (_pendingConnector != null)
                    {
                        ClearPendingConnector();
                    }
                    else
                    {
                        DeselectAll();
                    }
                    break;
                case "+":
                case "=":
                    _preventKeyDefault = true;
                    ZoomIn();
                    break;
                case "-":
                    _preventKeyDefault = true;
                    ZoomOut();
                    break;
                case "ArrowUp":
                    _preventKeyDefault = true;
                    MoveSelectedNodes(0, -10);
                    break;
                case "ArrowDown":
                    _preventKeyDefault = true;
                    MoveSelectedNodes(0, 10);
                    break;
                case "ArrowLeft":
                    _preventKeyDefault = true;
                    MoveSelectedNodes(-10, 0);
                    break;
                case "ArrowRight":
                    _preventKeyDefault = true;
                    MoveSelectedNodes(10, 0);
                    break;
                case "d":
                    _preventKeyDefault = true;
                    ToggleSelectedNodesDisabled();
                    break;
            }
        }
    }

    private void ToggleSelectedNodesDisabled()
    {
        if (_selectedNodes.Count == 0) return;

        var anyEnabled = _selectedNodes.Any(n => !n.IsDisabled);
        foreach (var node in _selectedNodes)
        {
            node.IsDisabled = anyEnabled; // If any enabled, disable all; else enable all
        }
        ValidateAllNodes();
        _diagram.Refresh();
        Notification.ShowInfo(anyEnabled ? "Nodes disabled" : "Nodes enabled");
    }

    private void DeselectAll()
    {
        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>().Where(n => n.Selected).ToList())
        {
            _diagram.UnselectModel(node);
        }
        _selectedNodes.Clear();
        _selectedNode = null;
        _selectedConfigSchema = null;
        StateHasChanged();
    }

    private void MoveSelectedNodes(double dx, double dy)
    {
        if (_selectedNodes.Count == 0) return;
        foreach (var node in _selectedNodes)
        {
            var x = (node.Position?.X ?? 0) + dx;
            var y = (node.Position?.Y ?? 0) + dy;
            if (_snapToGrid)
            {
                x = SnapToGridValue(x);
                y = SnapToGridValue(y);
            }
            node.SetPosition(x, y);
        }
        _diagram.Refresh();
    }

    private void ToggleSnapToGrid()
    {
        _snapToGrid = !_snapToGrid;
        if (_snapToGrid)
        {
            // Snap all nodes to grid
            foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
            {
                var x = SnapToGridValue(node.Position?.X ?? 0);
                var y = SnapToGridValue(node.Position?.Y ?? 0);
                node.SetPosition(x, y);
            }
            _diagram.Refresh();
        }
        Notification.ShowInfo(_snapToGrid ? "Snap to Grid enabled" : "Snap to Grid disabled");
    }

    private double SnapToGridValue(double value)
    {
        return Math.Round(value / GridSize) * GridSize;
    }

    // Node search
    private async Task OpenSearch()
    {
        _showSearch = true;
        _searchQuery = "";
        _searchResults.Clear();
        _searchResultIndex = 0;
        StateHasChanged();
        await Task.Delay(50); // Wait for render
        if (_searchField != null)
        {
            await _searchField.FocusAsync();
