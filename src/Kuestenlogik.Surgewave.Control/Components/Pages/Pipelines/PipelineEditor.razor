        if (_isNew || Id is null || !_debugMode) return;
        try
        {
            await InvokeAsync(async () =>
            {
                _debugState = await ApiClient.GetDebugStateAsync(Id);
                if (_debugState != null)
                {
                    foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
                    {
                        node.HasBreakpoint = _debugState.Breakpoints.Contains(node.NodeId);
                        if (_debugState.PausedNodes.TryGetValue(node.NodeId, out var paused))
                        {
                            node.IsPaused = true;
                            node.QueueDepth = paused.QueueDepth;
                        }
                        else
                        {
                            node.IsPaused = false;
                            node.QueueDepth = 0;
                        }
                    }
                    _diagram.Refresh();
                }
                StateHasChanged();
            });
        }
        catch
        {
