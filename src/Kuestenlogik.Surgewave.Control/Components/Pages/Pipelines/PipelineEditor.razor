    private void Paste()
    {
        var clipboardNodes = _editorState.GetClipboardNodes();
        if (clipboardNodes.Count == 0) return;

        SaveStateForUndo("Paste nodes");

        // Calculate paste position (offset from last paste or center of view)
        var baseX = 100.0;
        var baseY = 100.0;
        if (_diagram.Nodes.Any())
        {
            baseX = _diagram.Nodes.Max(n => n.Position?.X ?? 0) + 200;
        }

        foreach (var cn in clipboardNodes)
        {
            var node = new ConnectorNode(new Point(baseX + cn.RelativeX, baseY + cn.RelativeY))
            {
                NodeId = Guid.NewGuid().ToString("N"),
                ConnectorType = cn.ConnectorType,
                Label = cn.Label != null ? cn.Label + " (copy)" : null,
                IsSource = DetermineIsSource(cn.ConnectorType),
                IsSink = DetermineIsSink(cn.ConnectorType)
            };
            foreach (var (key, value) in cn.Config)
            {
                node.Config[key] = value;
            }
            _diagram.Nodes.Add(node);
        }

        Notification.ShowInfo($"Pasted {clipboardNodes.Count} node(s)");
    }

