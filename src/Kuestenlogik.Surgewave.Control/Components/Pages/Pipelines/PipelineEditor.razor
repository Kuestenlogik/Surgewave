    private async Task ValidateAsync()
    {
        if (Id == null) return;
        _validating = true;
        _validationIssues.Clear();
        StateHasChanged();

        try
        {
            var result = await ApiClient.ValidatePipelineAsync(Id);
            _validationIssues = result?.Issues ?? [];

            // Apply validation state to nodes
            foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
            {
                var issues = _validationIssues.Where(i => i.NodeId == node.NodeId).ToList();
                if (issues.Any(i => i.Severity == "Error"))
                {
                    node.ValidationState = NodeValidationState.Error;
                    node.ValidationMessage = string.Join("; ", issues.Where(i => i.Severity == "Error").Select(i => i.Message));
                }
                else if (issues.Any(i => i.Severity == "Warning"))
                {
                    node.ValidationState = NodeValidationState.Warning;
                    node.ValidationMessage = string.Join("; ", issues.Where(i => i.Severity == "Warning").Select(i => i.Message));
                }
                else
                {
                    node.ValidationState = NodeValidationState.Valid;
                    node.ValidationMessage = null;
                }

                // Store issues as JSON in config for NodeConfigPanel display
                if (issues.Count > 0)
                {
                    node.Config["_validation"] = System.Text.Json.JsonSerializer.Serialize(
                        issues.Select(i => new { i.Severity, i.Code, i.Message }));
                }
                else
                {
                    node.Config.Remove("_validation");
                }
            }

            _diagram.Refresh();

            if (_validationErrors > 0)
                Notification.ShowWarning($"Validation: {_validationErrors} error(s), {_validationIssues.Count - _validationErrors} warning(s)");
            else if (_validationIssues.Count > 0)
                Notification.ShowInfo($"Validation: {_validationIssues.Count} warning(s), no errors");
            else
                Notification.ShowSuccess("Validation passed — no issues");
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Validation failed: {ex.Message}");
        }
        finally
        {
            _validating = false;
            StateHasChanged();
        }
    }

