    private List<BreadcrumbItem> GetBreadcrumbItems()
    {
        var items = new List<BreadcrumbItem>();
        foreach (var entry in _breadcrumb.Reverse())
        {
            items.Add(new BreadcrumbItem(entry.Name, entry.PipelineId, icon: Icons.Material.Filled.AccountTree));
        }
        items.Add(new BreadcrumbItem(_pipelineName, null, disabled: true, icon: Icons.Material.Filled.Edit));
        return items;
    }

    private void OpenSubPipelineEditor(string? subPipelineId)
    {
        if (string.IsNullOrEmpty(subPipelineId)) return;

        // Push current state onto breadcrumb stack
        _breadcrumb.Push(new BreadcrumbEntry(
            Id ?? "new",
            _pipelineName,
            BuildPipelineDefinition()
        ));

        // Navigate to the sub-pipeline editor
        Navigation.NavigateTo($"/pipelines/{subPipelineId}/edit");
    }

    private void NavigateBreadcrumb(string pipelineId)
    {
        // Pop until we reach the target
        while (_breadcrumb.Count > 0)
        {
            var entry = _breadcrumb.Pop();
            if (entry.PipelineId == pipelineId)
            {
                Navigation.NavigateTo(
                    pipelineId == "new" ? "/pipelines/new" : $"/pipelines/{pipelineId}/edit");
                return;
            }
        }
    }

    private sealed record BreadcrumbEntry(string PipelineId, string Name, PipelineDefinition? SavedState);

    public async ValueTask DisposeAsync()
    {
        _autoSaveTimer?.Dispose();
        _metricsTimer?.Dispose();
        _debugTimer?.Dispose();
        _lineageHighlightCts?.Cancel();
        _lineageHighlightCts?.Dispose();
        _editorState.StateChanged -= StateHasChanged;
        if (_diagram != null)
        {
            _diagram.SelectionChanged -= OnSelectionChanged;
        }

        // Disconnect from collaboration hub
        if (_hubConnection != null)
        {
            try
            {
                if (!_isNew && Id != null)
                {
                    await _hubConnection.SendAsync("LeavePipeline", Id);
                }
                await _hubConnection.DisposeAsync();
            }
            catch
            {
                // Ignore errors during shutdown
            }
        }
    }

