    private async Task OnLineagePathReceived(string provenancePath)
    {
        // Parse pipe-delimited provenance path
        var nodeIds = provenancePath.Split('|', StringSplitOptions.RemoveEmptyEntries).ToList();
        if (nodeIds.Count > 0)
            await HighlightLineagePath(nodeIds);
    }

    private async Task HighlightLineagePath(List<string> nodeIds)
    {
        // Cancel any previous highlight timer
        _lineageHighlightCts?.Cancel();
        _lineageHighlightCts = new CancellationTokenSource();
        var ct = _lineageHighlightCts.Token;

        // Clear previous highlights
        ClearLineageHighlights();

        // Set highlights for matching nodes and links
        _highlightedLineageNodes.Clear();
        foreach (var id in nodeIds)
            _highlightedLineageNodes.Add(id);

        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
        {
            node.IsLineageHighlighted = _highlightedLineageNodes.Contains(node.NodeId);
        }

        // Highlight links between consecutive lineage nodes
        for (var i = 0; i < nodeIds.Count - 1; i++)
        {
            var sourceId = nodeIds[i];
            var targetId = nodeIds[i + 1];
            foreach (var link in _diagram.Links.OfType<PipelineLink>())
            {
                var linkSourceNode = _diagram.Nodes.OfType<ConnectorNode>()
                    .FirstOrDefault(n => n.Ports.Any(p => p == link.Source?.Model));
                var linkTargetNode = _diagram.Nodes.OfType<ConnectorNode>()
                    .FirstOrDefault(n => n.Ports.Any(p => p == link.Target?.Model));

                if (linkSourceNode?.NodeId == sourceId && linkTargetNode?.NodeId == targetId)
                {
                    link.IsLineageHighlighted = true;
                }
            }
        }

        _diagram.Refresh();
        StateHasChanged();

        // Auto-clear after 5 seconds
        try
        {
            await Task.Delay(5000, ct);
            ClearLineageHighlights();
            _diagram.Refresh();
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // New highlight started, ignore
        }
    }

    private void ClearLineageHighlights()
    {
        _highlightedLineageNodes.Clear();
        foreach (var node in _diagram.Nodes.OfType<ConnectorNode>())
            node.IsLineageHighlighted = false;
        foreach (var link in _diagram.Links.OfType<PipelineLink>())
            link.IsLineageHighlighted = false;
    }

    private async Task OpenPortMappingDialog(ConnectorNode node)
    {
        if (string.IsNullOrEmpty(node.SubPipelineId)) return;

        var parentInputPorts = _diagram.Nodes.OfType<ConnectorNode>()
            .Where(n => n.IsSource)
            .Select(n => n.NodeId)
            .ToList();
        var parentOutputPorts = _diagram.Nodes.OfType<ConnectorNode>()
            .Where(n => n.IsSink)
            .Select(n => n.NodeId)
            .ToList();

        SubPipelinePortMappingModel? existing = null;
        if (!string.IsNullOrEmpty(node.PortMappingsJson))
        {
            try
            {
                existing = System.Text.Json.JsonSerializer.Deserialize<SubPipelinePortMappingModel>(node.PortMappingsJson);
            }
            catch { /* ignore parse errors */ }
        }

        var parameters = new DialogParameters<PortMappingDialog>
        {
            { x => x.SubPipelineId, node.SubPipelineId },
            { x => x.SubPipelineName, node.SubPipelineName ?? "Sub-Pipeline" },
            { x => x.ParentInputPorts, parentInputPorts },
            { x => x.ParentOutputPorts, parentOutputPorts },
            { x => x.ExistingMapping, existing }
        };

        var dialog = await DialogService.ShowAsync<PortMappingDialog>("Port Mapping", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: SubPipelinePortMappingModel mapping })
        {
            node.PortMappingsJson = System.Text.Json.JsonSerializer.Serialize(mapping);
            node.InputPortLabels = mapping.InputMappings.Select(m => m.SubNodeLabel ?? m.SubPipelineNodeId).ToList();
            node.OutputPortLabels = mapping.OutputMappings.Select(m => m.SubNodeLabel ?? m.SubPipelineNodeId).ToList();
            _isDirty = true;
            _diagram.Refresh();
        }
    }

    private Dictionary<string, string> MergeParameters(string? environmentName)
    {
        var result = new Dictionary<string, string>();

        // Start with defaults
        foreach (var p in _parameters)
        {
            result[p.Name] = p.DefaultValue;
        }

        // Apply environment overrides
        if (environmentName != null)
        {
            var env = _environments.FirstOrDefault(e => e.Name == environmentName);
            if (env != null)
            {
                foreach (var (key, value) in env.Overrides)
                {
                    if (!string.IsNullOrEmpty(value))
                        result[key] = value;
                }
            }
        }

        return result;
    }

    private async Task OnVersionRestored(PipelineDefinition restored)
    {
        _pipeline = restored;
        _pipelineName = restored.Name;
        _pipelineDescription = restored.Description ?? "";

        // Rebuild diagram from restored definition
        _diagram.Nodes.Clear();
        _diagram.Links.Clear();

        foreach (var node in restored.Nodes)
        {
            var connectorNode = new ConnectorNode(new Point(node.X, node.Y))
            {
                NodeId = node.Id,
                ConnectorType = node.ConnectorType,
                Label = node.Label,
                IsSource = node.IsComposite ? false : DetermineIsSource(node.ConnectorType),
                IsSink = node.IsComposite ? false : DetermineIsSink(node.ConnectorType),
                SubPipelineId = node.SubPipelineId
            };

            foreach (var (key, value) in node.Config)
            {
                connectorNode.Config[key] = value;
            }

            if (node.IsComposite)
            {
                connectorNode.AddPort(PortAlignment.Left);
                connectorNode.AddPort(PortAlignment.Right);
            }

            _diagram.Nodes.Add(connectorNode);
        }

        foreach (var connection in restored.Connections)
        {
            var sourceNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == connection.SourceNodeId);
            var targetNode = _diagram.Nodes.OfType<ConnectorNode>().FirstOrDefault(n => n.NodeId == connection.TargetNodeId);

            if (sourceNode != null && targetNode != null)
            {
                var sourcePort = sourceNode.Ports.FirstOrDefault();
                var targetPort = targetNode.Ports.FirstOrDefault();

                if (sourcePort != null && targetPort != null)
                {
                    var link = new PipelineLink(sourcePort, targetPort)
                    {
                        ConnectionId = connection.Id,
                        InternalTopic = connection.InternalTopic
                    };
                    _diagram.Links.Add(link);
                }
            }
        }

        SaveStateForUndo("Restore version");
        Notification.ShowSuccess("Version restored");
        await Task.CompletedTask;
    }

