    private void ContextMenuDuplicateNode()
    {
        CloseContextMenu();
        if (_contextMenuNode == null) return;

        SaveStateForUndo("Duplicate node");
        var original = _contextMenuNode;
        var node = new ConnectorNode(new Point((original.Position?.X ?? 0) + 50, (original.Position?.Y ?? 0) + 50))
        {
            NodeId = Guid.NewGuid().ToString("N"),
            ConnectorType = original.ConnectorType,
            Label = original.Label != null ? original.Label + " (copy)" : null,
            IsSource = original.IsSource,
            IsSink = original.IsSink
        };

        foreach (var (key, value) in original.Config)
        {
            node.Config[key] = value;
        }

        if (original.IsSource)
        {
            node.AddPort(PortAlignment.Right);
        }
        else if (original.IsSink)
        {
            node.AddPort(PortAlignment.Left);
        }
        else
        {
            node.AddPort(PortAlignment.Left);
            node.AddPort(PortAlignment.Right);
        }

        _diagram.Nodes.Add(node);
        Notification.ShowInfo("Node duplicated");
    }

