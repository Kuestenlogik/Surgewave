    private void OnSubPipelineSelectedFromPalette(PipelineSummary pipeline)
    {
        _pendingSubPipelineId = pipeline.Id;
        _pendingSubPipelineName = pipeline.Name;

        // Create and place the sub-pipeline node immediately
        SaveStateForUndo("Add sub-pipeline node");

        // Place near center or offset from last node
        var baseX = 100.0;
        var baseY = 100.0;
        if (_diagram.Nodes.Any())
        {
            baseX = _diagram.Nodes.Max(n => n.Position?.X ?? 0) + 50;
            baseY = _diagram.Nodes.Average(n => n.Position?.Y ?? 0);
        }

        if (_snapToGrid)
        {
            baseX = SnapToGridValue(baseX);
            baseY = SnapToGridValue(baseY);
        }

        var node = new ConnectorNode(new Point(baseX, baseY))
        {
            NodeId = Guid.NewGuid().ToString("N"),
            ConnectorType = "SubPipeline",
            Label = pipeline.Name,
            IsSource = false,
            IsSink = false,
            SubPipelineId = pipeline.Id,
            SubPipelineName = pipeline.Name
        };
        node.Config["pipeline.id"] = pipeline.Id;

        // Composite nodes get both input and output ports
        node.AddPort(PortAlignment.Left);
        node.AddPort(PortAlignment.Right);

        _diagram.Nodes.Add(node);
        _pendingSubPipelineId = null;
        _pendingSubPipelineName = null;

        ValidateAllNodes();
        Notification.ShowInfo($"Sub-pipeline '{pipeline.Name}' added");
        StateHasChanged();
    }

    private PipelineDefinition BuildPipelineDefinition()
    {
        var nodes = _diagram.Nodes.OfType<ConnectorNode>()
            .Select(n => new PipelineNode
            {
                Id = n.NodeId,
                ConnectorType = n.ConnectorType,
                Config = new Dictionary<string, string>(n.Config),
                X = n.Position?.X ?? 0,
                Y = n.Position?.Y ?? 0,
                Label = n.Label,
                SubPipelineId = n.SubPipelineId,
                PortMappingsJson = n.PortMappingsJson,
                RetryPolicy = n.RetryPolicy
            })
            .ToList();

        var connections = _diagram.Links.OfType<PipelineLink>()
            .Select(l => new PipelineConnection
            {
                Id = l.ConnectionId,
                SourceNodeId = ((ConnectorNode?)l.Source?.Model)?.NodeId ?? "",
                TargetNodeId = ((ConnectorNode?)l.Target?.Model)?.NodeId ?? "",
                InternalTopic = l.InternalTopic,
                Type = l.IsErrorLink ? "error" : null
            })
            .Where(c => !string.IsNullOrEmpty(c.SourceNodeId) && !string.IsNullOrEmpty(c.TargetNodeId))
            .ToList();

        return new PipelineDefinition
        {
            Id = _pipeline?.Id ?? Guid.NewGuid().ToString("N"),
            Name = _pipelineName,
            Description = _pipelineDescription,
            Nodes = nodes,
            Connections = connections,
            Status = _pipeline?.Status ?? PipelineStatus.Draft,
            CreatedAt = _pipeline?.CreatedAt ?? DateTimeOffset.UtcNow,
            Parameters = _parameters,
            Environments = _environments,
            Schedule = _scheduleConfig
        };
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_pipelineName))
        {
            Notification.ShowWarning("Please enter a pipeline name");
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            var definition = BuildPipelineDefinition();

            if (_isNew)
            {
                _pipeline = await ApiClient.CreatePipelineAsync(definition.Name, definition.Description,
                    definition.Nodes, definition.Connections);
                Notification.ShowSuccess("Pipeline created");
                Navigation.NavigateTo($"/pipelines/{_pipeline.Id}/edit", replace: true);
            }
            else
            {
                _pipeline = await ApiClient.UpdatePipelineAsync(Id!, definition.Name, definition.Description,
                    definition.Nodes, definition.Connections);
                Notification.ShowSuccess("Pipeline saved");
            }
            _isDirty = false;
            _lastSaveTime = DateTime.Now;
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to save pipeline: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task AutoSaveAsync()
    {
        // Only auto-save if dirty and not a new pipeline
        if (!_isDirty || _isNew || _saving) return;

        try
        {
            await InvokeAsync(async () =>
            {
                var definition = BuildPipelineDefinition();
                _pipeline = await ApiClient.UpdatePipelineAsync(Id!, definition.Name, definition.Description,
                    definition.Nodes, definition.Connections);
                _isDirty = false;
                _lastSaveTime = DateTime.Now;
                StateHasChanged();
            });
        }
        catch
        {
            // Silently fail - user can manually save
        }
    }

    private async Task AnalyzeAndHotDeployAsync()
    {
        if (_pipeline == null || Id == null) return;
        _saving = true;
        StateHasChanged();

        try
        {
            var definition = BuildPipelineDefinition();
            var request = new UpdatePipelineRequest
            {
                Name = definition.Name,
                Description = definition.Description,
                Nodes = definition.Nodes,
                Connections = definition.Connections
            };

            var analysis = await ApiClient.AnalyzeChangesAsync(Id, request);
            if (analysis is { IsHotDeployable: true })
            {
                var success = await ApiClient.HotDeployAsync(Id, request);
                if (success)
                {
                    Notification.ShowSuccess("Changes hot-deployed successfully");
                    _isDirty = false;
                    _lastSaveTime = DateTime.Now;
                }
                else
                {
                    Notification.ShowWarning("Hot-deploy failed - changes require pipeline restart");
                }
            }
            else if (analysis is { RequiresRestart: true })
            {
                var reasons = string.Join("; ", analysis.RestartReasons);
                Notification.ShowWarning($"Cannot hot-deploy: {reasons}. Stop and restart the pipeline.");
            }
            else
            {
                Notification.ShowInfo("No config changes detected");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Hot-deploy failed: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task SaveAndStartAsync()
    {
        await SaveAsync();

        if (_pipeline != null)
        {
            try
            {
                if (_parameters.Count > 0)
                {
                    // Start with merged parameters (defaults + first environment if any)
                    var envName = _environments.Count > 0 ? _environments[0].Name : null;
                    var mergedParams = MergeParameters(envName);
                    await ApiClient.StartPipelineWithParametersAsync(_pipeline.Id, mergedParams);
                }
                else
                {
                    await ApiClient.StartPipelineAsync(_pipeline.Id);
                }
                Notification.ShowSuccess("Pipeline started");
                _pipelineIsRunning = true;
                StartMetricsTimer();
            }
            catch (Exception ex)
            {
                Notification.ShowError($"Failed to start pipeline: {ex.Message}");
            }
        }
    }

