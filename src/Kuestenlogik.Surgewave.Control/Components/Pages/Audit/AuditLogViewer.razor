@page "/audit"
@using Kuestenlogik.Surgewave.Control.Models
@using Kuestenlogik.Surgewave.Control.Services
@inject IAuditApiClient AuditApiClient
@inject NotificationState Notification
@inject IJSRuntime JSRuntime

<PageTitle>Audit Logs - Surgewave Control</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Audit Logs</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_timeRange" Label="Time Range" Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value="@("1h")">Last Hour</MudSelectItem>
                <MudSelectItem Value="@("6h")">Last 6 Hours</MudSelectItem>
                <MudSelectItem Value="@("24h")">Last 24 Hours</MudSelectItem>
                <MudSelectItem Value="@("7d")">Last 7 Days</MudSelectItem>
                <MudSelectItem Value="@("custom")">Custom Range</MudSelectItem>
            </MudSelect>
        </MudItem>

        @if (_timeRange == "custom")
        {
            <MudItem xs="12" md="2">
                <MudDatePicker @bind-Date="_customStartDate" Label="Start Date" Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker @bind-Date="_customEndDate" Label="End Date" Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
        }

        <MudItem xs="12" md="2">
            <MudSelect T="string" @bind-Value="_filterEventType" Label="Event Type" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Clearable="true">
                @foreach (var type in _eventTypes)
                {
                    <MudSelectItem Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="2">
            <MudSelect T="string" @bind-Value="_filterSuccessStr" Label="Status" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Clearable="true">
                <MudSelectItem Value="@("true")">Success</MudSelectItem>
                <MudSelectItem Value="@("false")">Failed</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="2" Class="d-flex align-center gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadEventsAsync"
                       StartIcon="@Icons.Material.Filled.Search" Disabled="@_loading">
                Filter
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ExportAsync"
                       StartIcon="@Icons.Material.Filled.Download" Disabled="@(_events.Count == 0)">
                Export
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-2">
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_filterPrincipal" Label="Principal" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Placeholder="User:alice" Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_filterResourceType" Label="Resource Type" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Placeholder="topic, acl, connector..." Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_filterResourceName" Label="Resource Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Placeholder="my-topic" Clearable="true" />
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

@if (_stats != null)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1">Status</MudText>
                <MudChip T="string" Color="@(_stats.Enabled ? Color.Success : Color.Error)">
                    @(_stats.Enabled ? "Enabled" : "Disabled")
                </MudChip>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1">Recent Events</MudText>
                <MudText Typo="Typo.h5">@_stats.RecentEventCount.ToString("N0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1">Broker ID</MudText>
                <MudText Typo="Typo.h5">@_stats.BrokerId</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<MudTable Items="@_events" Dense="true" Hover="true" Striped="true" Loading="@_loading"
          LoadingProgressColor="Color.Primary">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Audit Events</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2">
            @_events.Count of @_totalCount events
            @if (_hasMore)
            {
                <span>(more available)</span>
            }
        </MudText>
    </ToolBarContent>
    <HeaderContent>
        <MudTh Style="width: 150px">Timestamp</MudTh>
        <MudTh Style="width: 120px">Event Type</MudTh>
        <MudTh Style="width: 80px">Status</MudTh>
        <MudTh>Principal</MudTh>
        <MudTh>Resource</MudTh>
        <MudTh Style="width: 100px">Details</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Timestamp">
            <MudTooltip Text="@context.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss.fff")">
                <MudText Typo="Typo.body2">@FormatTime(context.TimestampUtc)</MudText>
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Event Type">
            <MudChip T="string" Size="Size.Small" Color="@GetEventTypeColor(context.EventType)">
                @context.EventType
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Status">
            @if (context.Success)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudTooltip Text="@context.ErrorMessage">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                </MudTooltip>
            }
        </MudTd>
        <MudTd DataLabel="Principal">
            <MudText Typo="Typo.body2">@(context.Principal ?? "-")</MudText>
            @if (context.ClientAddress != null)
            {
                <MudText Typo="Typo.caption">@context.ClientAddress</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Resource">
            @if (context.ResourceType != null)
            {
                <MudText Typo="Typo.body2">@context.ResourceType: @(context.ResourceName ?? "*")</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2">-</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Details">
            @if (context.Details?.Count > 0)
            {
                <MudTooltip>
                    <ChildContent>
                        <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                    </ChildContent>
                    <TooltipContent>
                        <div style="max-width: 300px">
                            @foreach (var kvp in context.Details)
                            {
                                <div><strong>@kvp.Key:</strong> @kvp.Value</div>
                            }
                        </div>
                    </TooltipContent>
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <div class="d-flex align-center justify-end pa-4">
            @if (_hasMore)
            {
                <MudButton Variant="Variant.Outlined" OnClick="LoadMoreAsync" Disabled="@_loading">
                    Load More
                </MudButton>
            }
        </div>
    </PagerContent>
    <NoRecordsContent>
        <MudText>No audit events found for the selected filters</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private bool _loading = true;
    private string _timeRange = "1h";
    private DateTime? _customStartDate;
    private DateTime? _customEndDate;
    private string _filterEventType = "";
    private string _filterPrincipal = "";
    private string _filterResourceType = "";
    private string _filterResourceName = "";
    private string _filterSuccessStr = "";

    private bool? FilterSuccess => _filterSuccessStr switch
    {
        "true" => true,
        "false" => false,
        _ => null
    };

    private string? GetFilterValue(string value) => string.IsNullOrWhiteSpace(value) ? null : value;

    private AuditStatsModel? _stats;
    private List<AuditEventModel> _events = [];
    private int _totalCount;
    private bool _hasMore;
    private int _currentOffset;

    private static readonly string[] _eventTypes =
    [
        "TopicCreated", "TopicDeleted", "TopicAltered", "PartitionsAdded", "RecordsDeleted",
        "AclCreated", "AclDeleted",
        "ConnectorCreated", "ConnectorDeleted", "ConnectorPaused", "ConnectorResumed",
        "AuthenticationAttempt", "AuthenticationSuccess", "AuthenticationFailed", "AuthorizationCheck",
        "ConsumerGroupDeleted", "OffsetsCommitted",
        "TransactionCommitted", "TransactionAborted",
        "SchemaRegistered", "SchemaDeleted",
        "ConfigChanged"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            await Task.WhenAll(
                LoadStatsAsync(),
                LoadEventsAsync());
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadStatsAsync()
    {
        _stats = await AuditApiClient.GetStatsAsync();
    }

    private async Task LoadEventsAsync()
    {
        _loading = true;
        _currentOffset = 0;
        _events.Clear();
        StateHasChanged();

        try
        {
            var (start, end) = GetTimeRange();
            var result = await AuditApiClient.QueryEventsAsync(
                start: start,
                end: end,
                eventType: GetFilterValue(_filterEventType),
                principal: string.IsNullOrWhiteSpace(_filterPrincipal) ? null : _filterPrincipal,
                resourceType: string.IsNullOrWhiteSpace(_filterResourceType) ? null : _filterResourceType,
                resourceName: string.IsNullOrWhiteSpace(_filterResourceName) ? null : _filterResourceName,
                success: FilterSuccess,
                limit: 50,
                offset: 0);

            _events = result.Events;
            _totalCount = result.TotalCount;
            _hasMore = result.HasMore;
            _currentOffset = _events.Count;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var (start, end) = GetTimeRange();
            var result = await AuditApiClient.QueryEventsAsync(
                start: start,
                end: end,
                eventType: GetFilterValue(_filterEventType),
                principal: string.IsNullOrWhiteSpace(_filterPrincipal) ? null : _filterPrincipal,
                resourceType: string.IsNullOrWhiteSpace(_filterResourceType) ? null : _filterResourceType,
                resourceName: string.IsNullOrWhiteSpace(_filterResourceName) ? null : _filterResourceName,
                success: FilterSuccess,
                limit: 50,
                offset: _currentOffset);

            _events.AddRange(result.Events);
            _hasMore = result.HasMore;
            _currentOffset = _events.Count;
        }
        finally
        {
            _loading = false;
        }
    }

    private (DateTimeOffset? start, DateTimeOffset? end) GetTimeRange()
    {
        var now = DateTimeOffset.UtcNow;
        return _timeRange switch
        {
            "1h" => (now.AddHours(-1), now),
            "6h" => (now.AddHours(-6), now),
            "24h" => (now.AddDays(-1), now),
            "7d" => (now.AddDays(-7), now),
            "custom" => (
                _customStartDate.HasValue ? new DateTimeOffset(_customStartDate.Value, TimeSpan.Zero) : null,
                _customEndDate.HasValue ? new DateTimeOffset(_customEndDate.Value.AddDays(1), TimeSpan.Zero) : null),
            _ => (now.AddHours(-1), now)
        };
    }

    private async Task ExportAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_events, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var fileName = $"audit-export-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json";
            // Note: Actual download requires JS interop
            Notification.ShowInfo($"Export prepared: {_events.Count} events");
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Export failed: {ex.Message}");
        }
    }

    private static string FormatTime(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return time.ToString("MM/dd HH:mm");
    }

    private static Color GetEventTypeColor(string eventType) => eventType switch
    {
        "TopicCreated" or "AclCreated" or "ConnectorCreated" or "SchemaRegistered" => Color.Success,
        "TopicDeleted" or "AclDeleted" or "ConnectorDeleted" or "SchemaDeleted" or "ConsumerGroupDeleted" => Color.Error,
        "AuthenticationFailed" => Color.Error,
        "AuthenticationSuccess" => Color.Success,
        "TopicAltered" or "ConfigChanged" or "PartitionsAdded" => Color.Warning,
        _ => Color.Default
    };
}
