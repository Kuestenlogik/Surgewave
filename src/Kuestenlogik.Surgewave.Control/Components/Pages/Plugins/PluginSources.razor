@page "/plugins/sources"
@using Kuestenlogik.Surgewave.Plugins.Sources
@inject ISnackbar Snackbar

<PageTitle>Plugin Sources - Surgewave Control</PageTitle>

<PageHead Title="Plugin Sources" />

<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    Configure where Surgewave discovers and downloads plugins from. Sources are searched in order when installing plugins.
</MudText>

@* Add Source Form *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Add Source</MudText>
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_newName" Label="Name" Placeholder="e.g., mycompany" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudSelect @bind-Value="_newType" Label="Type" Variant="Variant.Outlined">
                <MudSelectItem Value="@("nuget")">NuGet Feed</MudSelectItem>
                <MudSelectItem Value="@("http")">HTTP / Marketplace</MudSelectItem>
                <MudSelectItem Value="@("github")">GitHub Releases</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_newUrl" Label="URL" Placeholder="https://..." Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_newApiKey" Label="API Key" Placeholder="optional" Variant="Variant.Outlined" InputType="InputType.Password" />
        </MudItem>
        <MudItem xs="12" md="1" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddSource" FullWidth="true">Add</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* Source List *@
<MudTable Items="_sources" Hover="true" Elevation="2">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>URL</MudTh>
        <MudTh>API Key</MudTh>
        <MudTh Style="width:100px">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="GetTypeColor(context.Type)">@context.Type</MudChip></MudTd>
        <MudTd><code>@context.Url</code></MudTd>
        <MudTd>@(string.IsNullOrEmpty(context.ApiKey) ? "—" : "••••••")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => RemoveSource(context.Name))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No plugin sources configured. Add one above.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private PluginSourceConfig _config = new();
    private List<PluginSourceConfig.SourceEntry> _sources = [];
    private string _newName = "";
    private string _newType = "nuget";
    private string _newUrl = "";
    private string? _newApiKey;

    protected override void OnInitialized()
    {
        _config = PluginSourceConfig.Load();
        _sources = _config.Sources;
    }

    private void AddSource()
    {
        if (string.IsNullOrWhiteSpace(_newName))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newUrl))
        {
            Snackbar.Add("URL is required.", Severity.Warning);
            return;
        }

        if (_sources.Any(s => s.Name.Equals(_newName, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"A source named '{_newName}' already exists.", Severity.Warning);
            return;
        }

        _sources.Add(new PluginSourceConfig.SourceEntry
        {
            Name = _newName,
            Type = _newType,
            Url = _newUrl,
            ApiKey = string.IsNullOrWhiteSpace(_newApiKey) ? null : _newApiKey
        });

        _config.Save();
        Snackbar.Add($"Source '{_newName}' added.", Severity.Success);

        _newName = "";
        _newUrl = "";
        _newApiKey = null;
    }

    private void RemoveSource(string name)
    {
        var entry = _sources.FirstOrDefault(s => s.Name == name);
        if (entry is null) return;

        _sources.Remove(entry);
        _config.Save();
        Snackbar.Add($"Source '{name}' removed.", Severity.Info);
    }

    private static Color GetTypeColor(string type) => type.ToLowerInvariant() switch
    {
        "nuget" => Color.Secondary,
        "http" => Color.Info,
        "github" => Color.Dark,
        _ => Color.Default
    };
}
