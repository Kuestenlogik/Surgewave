@page "/plugins/sources"
@using Kuestenlogik.Surgewave.Plugins.Sources
@inject ISnackbar Snackbar

<PageTitle>Plugin Sources - Surgewave Control</PageTitle>

<PageHead Title="Plugin Sources"
          Subtitle="Where Surgewave discovers and downloads plugins from — searched in order at install time." />

<div class="surgewave-section-title">Add source</div>

<MudPaper Class="surgewave-surface mb-4">
    <div class="d-flex align-center gap-2">
        <MudTextField @bind-Value="_newName" Label="Name" Placeholder="e.g., mycompany"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 180px;" />
        <MudSelect @bind-Value="_newType" Label="Type" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Style="width: 200px;">
            <MudSelectItem Value="@("nuget")">NuGet Feed</MudSelectItem>
            <MudSelectItem Value="@("http")">HTTP / Marketplace</MudSelectItem>
            <MudSelectItem Value="@("github")">GitHub Releases</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_newUrl" Label="URL" Placeholder="https://…"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
        <MudTextField @bind-Value="_newApiKey" Label="API key" Placeholder="optional"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 200px;"
                      InputType="InputType.Password" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddSource">
            Add
        </MudButton>
    </div>
</MudPaper>

<div class="surgewave-section-title">Configured sources</div>

<MudPaper Class="surgewave-surface" Style="padding: 0;">
<MudTable Items="_sources" Hover="true" Elevation="0">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>URL</MudTh>
        <MudTh>API key</MudTh>
        <MudTh Style="width:80px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><strong>@context.Name</strong></MudTd>
        <MudTd>
            <span class="surgewave-status @GetTypeStatusClass(context.Type)">
                <span class="surgewave-status-dot"></span>
                @context.Type
            </span>
        </MudTd>
        <MudTd><span class="surgewave-mono">@context.Url</span></MudTd>
        <MudTd><span class="surgewave-mono">@(string.IsNullOrEmpty(context.ApiKey) ? "—" : "••••••")</span></MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => RemoveSource(context.Name))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4">No plugin sources configured. Add one above.</MudText>
    </NoRecordsContent>
</MudTable>
</MudPaper>

@code {
    private PluginSourceConfig _config = new();
    private List<PluginSourceConfig.SourceEntry> _sources = [];
    private string _newName = "";
    private string _newType = "nuget";
    private string _newUrl = "";
    private string? _newApiKey;

    protected override void OnInitialized()
    {
        _config = PluginSourceConfig.Load();
        _sources = _config.Sources;
    }

    private void AddSource()
    {
        if (string.IsNullOrWhiteSpace(_newName))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newUrl))
        {
            Snackbar.Add("URL is required.", Severity.Warning);
            return;
        }

        if (_sources.Any(s => s.Name.Equals(_newName, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"A source named '{_newName}' already exists.", Severity.Warning);
            return;
        }

        _sources.Add(new PluginSourceConfig.SourceEntry
        {
            Name = _newName,
            Type = _newType,
            Url = _newUrl,
            ApiKey = string.IsNullOrWhiteSpace(_newApiKey) ? null : _newApiKey
        });

        _config.Save();
        Snackbar.Add($"Source '{_newName}' added.", Severity.Success);

        _newName = "";
        _newUrl = "";
        _newApiKey = null;
    }

    private void RemoveSource(string name)
    {
        var entry = _sources.FirstOrDefault(s => s.Name == name);
        if (entry is null) return;

        _sources.Remove(entry);
        _config.Save();
        Snackbar.Add($"Source '{name}' removed.", Severity.Info);
    }

    private static Color GetTypeColor(string type) => type.ToLowerInvariant() switch
    {
        "nuget" => Color.Secondary,
        "http" => Color.Info,
        "github" => Color.Dark,
        _ => Color.Default
    };

    private static string GetTypeStatusClass(string type) => type.ToLowerInvariant() switch
    {
        "nuget" => "surgewave-status--info",
        "http" => "surgewave-status--info",
        "github" => "surgewave-status--idle",
        _ => ""
    };
}
