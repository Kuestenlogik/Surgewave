@page "/health"
@inject ISurgewaveApiClient ApiClient
@inject ClusterState ClusterState

<PageTitle>Health - Surgewave Control</PageTitle>

<PageHead Title="Cluster Health"
          Subtitle="Broker, gRPC, storage and Raft consensus checks.">
    <Actions>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                       Size="Size.Small" OnClick="LoadDataAsync" Disabled="_loading" />
    </Actions>
</PageHead>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Failed to load health details: @_error
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadDataAsync" Class="ml-4">
            Retry
        </MudButton>
    </MudAlert>
}
else if (_healthDetails != null)
{
    <SummaryStrip>
        <Stat Label="Status">
            <span class="surgewave-status @(_isHealthy ? "surgewave-status--ok" : "surgewave-status--error")">
                <span class="surgewave-status-dot"></span>
                @_healthDetails.Status
            </span>
        </Stat>
        <Stat Label="Broker"
              Value="@($"#{_healthDetails.BrokerId} · {(_healthDetails.Host.Length > 0 ? _healthDetails.Host : "localhost")}:{(_healthDetails.Port > 0 ? _healthDetails.Port : 9092)}")"
              Mono="true" />
        <Stat Label="Controller" Value="@($"Broker {_healthDetails.ControllerId}")" Mono="true" />
        <Stat Label="Brokers / Topics"
              Value="@($"{_healthDetails.BrokersCount} / {_healthDetails.TopicsCount}")" Mono="true" />
        @if (_healthDetails.RaftEnabled)
        {
            <Stat Label="Raft">
                <span class="surgewave-status @GetRaftStatusClass(_healthDetails.RaftState)">
                    <span class="surgewave-status-dot"></span>
                    @($"{_healthDetails.RaftState} · Broker {_healthDetails.RaftLeaderId ?? -1}")
                </span>
            </Stat>
        }
        <Stat Label="Last checked"
              Value="@_healthDetails.Timestamp.ToLocalTime().ToString("HH:mm:ss")"
              Mono="true" />
    </SummaryStrip>

    <div class="surgewave-section-title">Health checks</div>

    <MudPaper Class="surgewave-surface" Style="padding: 0;">
        <MudSimpleTable Dense="true" Hover="true" Elevation="0">
            <thead>
                <tr>
                    <th>Check</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Broker</strong></td>
                    <td>
                        <span class="surgewave-status @GetCheckStatusClass(_healthDetails.Checks?.Broker, _isHealthy)">
                            <span class="surgewave-status-dot"></span>
                            @(_healthDetails.Checks?.Broker ?? (_isHealthy ? "Healthy" : "Unhealthy"))
                        </span>
                    </td>
                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Kafka protocol listener</MudText></td>
                </tr>
                <tr>
                    <td><strong>gRPC API</strong></td>
                    <td>
                        <span class="surgewave-status @GetCheckStatusClass(_healthDetails.Checks?.Grpc, true)">
                            <span class="surgewave-status-dot"></span>
                            @(_healthDetails.Checks?.Grpc ?? "Healthy")
                        </span>
                    </td>
                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">REST / gRPC endpoints</MudText></td>
                </tr>
                <tr>
                    <td><strong>Storage</strong></td>
                    <td>
                        <span class="surgewave-status @GetCheckStatusClass(_healthDetails.Checks?.Storage, false)">
                            <span class="surgewave-status-dot"></span>
                            @(_healthDetails.Checks?.Storage ?? "Unknown")
                        </span>
                    </td>
                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Log segments accessible</MudText></td>
                </tr>
                @if (_healthDetails.RaftEnabled)
                {
                    var raftHealthy = _healthDetails.RaftState is "Leader" or "Follower";
                    <tr>
                        <td><strong>Raft Consensus</strong></td>
                        <td>
                            <span class="surgewave-status @(raftHealthy ? "surgewave-status--ok" : "surgewave-status--warn")">
                                <span class="surgewave-status-dot"></span>
                                @(_healthDetails.RaftState == "Candidate" ? "Election in progress" : "Healthy")
                            </span>
                        </td>
                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Cluster replication</MudText></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private string? _error;
    private bool _isHealthy;
    private HealthDetails? _healthDetails;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _healthDetails = await ApiClient.GetHealthDetailsAsync();
            _isHealthy = _healthDetails?.Status == "Healthy";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _isHealthy = false;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static Color GetRaftStateColor(string? state) => state switch
    {
        "Leader" => Color.Success,
        "Follower" => Color.Info,
        "Candidate" => Color.Warning,
        _ => Color.Default
    };

    private static string GetRaftStatusClass(string? state) => state switch
    {
        "Leader" => "surgewave-status--ok",
        "Follower" => "surgewave-status--info",
        "Candidate" => "surgewave-status--warn",
        _ => "surgewave-status--idle"
    };

    private static Color GetCheckColor(string? status) => status switch
    {
        "Healthy" => Color.Success,
        "Unhealthy" => Color.Error,
        "Degraded" => Color.Warning,
        "Unknown" => Color.Default,
        _ => Color.Default
    };

    private static string GetCheckStatusClass(string? status, bool fallbackHealthy)
    {
        var s = status ?? (fallbackHealthy ? "Healthy" : "Unhealthy");
        return s switch
        {
            "Healthy" => "surgewave-status--ok",
            "Unhealthy" => "surgewave-status--error",
            "Degraded" => "surgewave-status--warn",
            "Unknown" => "surgewave-status--idle",
            _ => ""
        };
    }
}
