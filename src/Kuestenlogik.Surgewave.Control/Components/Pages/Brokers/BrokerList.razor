@page "/brokers"
@inject ISurgewaveApiClient ApiClient
@inject ClusterState ClusterState

<PageTitle>Brokers - Surgewave Control</PageTitle>

<PageHead Title="Brokers"
          Subtitle="Broker inventory, controller status, and partition leadership.">
    <Actions>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                       Size="Size.Small" OnClick="LoadBrokersAsync" Disabled="_loading" />
    </Actions>
</PageHead>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        @_error
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadBrokersAsync" Class="ml-4">
            Retry
        </MudButton>
    </MudAlert>
}
else
{
    <SummaryStrip>
        <Stat Label="Total brokers" Value="@_brokers.Count.ToString()" />
        <Stat Label="Controller">
            @{
                var controller = _brokers.FirstOrDefault(b => b.IsController);
            }
            @if (controller is not null)
            {
                <span class="surgewave-status surgewave-status--info">
                    <span class="surgewave-status-dot"></span>
                    @($"Broker {controller.BrokerId}")
                </span>
            }
            else
            {
                <span class="surgewave-stat-value--muted">—</span>
            }
        </Stat>
        <Stat Label="Status">
            <span class="surgewave-status @(_isHealthy ? "surgewave-status--ok" : "surgewave-status--error")">
                <span class="surgewave-status-dot"></span>
                @(_isHealthy ? "Healthy" : "Unhealthy")
            </span>
        </Stat>
    </SummaryStrip>

    <MudGrid>
        @* Broker Cards *@
        @foreach (var broker in _brokers.OrderBy(b => b.BrokerId))
        {
            <MudItem xs="12" md="6" lg="4">
                <MudCard Elevation="0">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="@(broker.IsController ? Color.Warning : Color.Primary)">
                                @broker.BrokerId
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Broker @broker.BrokerId</MudText>
                            <span class="surgewave-mono">@broker.Host:@broker.Port</span>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (broker.IsController)
                            {
                                <MudTooltip Text="Controller">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                </MudTooltip>
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Host</MudText></td>
                                    <td><span class="surgewave-mono">@broker.Host</span></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Port</MudText></td>
                                    <td><span class="surgewave-mono">@broker.Port</span></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Rack</MudText></td>
                                    <td>
                                        @if (broker.Rack is null)
                                        {
                                            <span class="surgewave-stat-value--muted">—</span>
                                        }
                                        else
                                        {
                                            <span class="surgewave-mono">@broker.Rack</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Peer Transport</MudText></td>
                                    <td>
                                        @if (string.Equals(broker.PeerTransport, "quic", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="surgewave-status surgewave-status--info">
                                                <span class="surgewave-status-dot"></span>
                                                QUIC
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="surgewave-status">
                                                <span class="surgewave-status-dot"></span>
                                                TCP
                                            </span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Role</MudText></td>
                                    <td>
                                        @if (broker.IsController)
                                        {
                                            <span class="surgewave-status surgewave-status--warn">
                                                <span class="surgewave-status-dot"></span>
                                                Controller
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="surgewave-status">
                                                <span class="surgewave-status-dot"></span>
                                                Replica
                                            </span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary"
                                   Href="@($"/brokers/{broker.BrokerId}")">
                            View Details
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<BrokerInfo> _brokers = [];
    private HealthDetails? _healthDetails;
    private bool _isHealthy;

    protected override async Task OnInitializedAsync()
    {
        ClusterState.OnChange += async () =>
        {
            await LoadBrokersAsync();
            StateHasChanged();
        };
        await LoadBrokersAsync();
    }

    private async Task LoadBrokersAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var clusterId = ClusterState.SelectedClusterId;
            _brokers = (await ApiClient.ListBrokersAsync(clusterId)).ToList();

            // Load health details
            _healthDetails = await ApiClient.GetHealthDetailsAsync();
            _isHealthy = _healthDetails?.Status == "Healthy";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _isHealthy = false;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
