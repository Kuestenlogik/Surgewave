@page "/brokers/{BrokerId:int}"
@inject ISurgewaveApiClient ApiClient
@inject ClusterState ClusterState

<PageTitle>Broker @BrokerId - Surgewave Control</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        @_error
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadBrokerAsync" Class="ml-4">
            Retry
        </MudButton>
    </MudAlert>
}
else if (_broker != null)
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-2" />

    <PageHead Title="@($"Broker {_broker.BrokerId}")"
              Subtitle="Partition leadership and replica assignments.">
        <Actions>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                           Size="Size.Small" OnClick="LoadBrokerAsync" Disabled="_loading" />
        </Actions>
    </PageHead>

    <SummaryStrip>
        <Stat Label="Endpoint" Value="@($"{_broker.Host}:{_broker.Port}")" Mono="true" />
        <Stat Label="Role">
            @if (_broker.IsController)
            {
                <span class="surgewave-status surgewave-status--warn">
                    <span class="surgewave-status-dot"></span>
                    Controller
                </span>
            }
            else
            {
                <span class="surgewave-status">
                    <span class="surgewave-status-dot"></span>
                    Replica
                </span>
            }
        </Stat>
        <Stat Label="Status">
            <span class="surgewave-status @(_isOnline ? "surgewave-status--ok" : "surgewave-status--error")">
                <span class="surgewave-status-dot"></span>
                @(_isOnline ? "Online" : "Offline")
            </span>
        </Stat>
        <Stat Label="Rack" Value="@(_broker.Rack ?? "—")" Muted="@(_broker.Rack is null)" />
        <Stat Label="Leader / Replica"
              Value="@($"{_leaderPartitions.Count} / {_replicaPartitions.Count}")" />
    </SummaryStrip>

    <div class="surgewave-section-title">Partition leadership</div>

    <MudPaper Class="surgewave-surface" Style="padding: 0;">
        @if (_leaderPartitions.Count == 0 && _replicaPartitions.Count == 0)
        {
            <MudText Color="Color.Secondary" Class="pa-6">No partitions assigned to this broker.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>Topic</th>
                        <th>Partition</th>
                        <th>Role</th>
                        <th>Replicas</th>
                        <th>ISR</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _leaderPartitions.Concat(_replicaPartitions).OrderBy(x => x.Topic).ThenBy(x => x.PartitionId))
                    {
                        var isrIncomplete = p.Isr.Count != p.Replicas.Count;
                        <tr>
                            <td>
                                <MudLink Href="@($"/topics/{p.Topic}")" Class="surgewave-mono">@p.Topic</MudLink>
                            </td>
                            <td><span class="surgewave-mono">@p.PartitionId</span></td>
                            <td>
                                @if (p.IsLeader)
                                {
                                    <span class="surgewave-status surgewave-status--ok">
                                        <span class="surgewave-status-dot"></span>
                                        Leader
                                    </span>
                                }
                                else
                                {
                                    <span class="surgewave-status">
                                        <span class="surgewave-status-dot"></span>
                                        Replica
                                    </span>
                                }
                            </td>
                            <td><span class="surgewave-mono">@string.Join(", ", p.Replicas)</span></td>
                            <td>
                                <span class="surgewave-status @(isrIncomplete ? "surgewave-status--warn" : "surgewave-status--ok")">
                                    <span class="surgewave-status-dot"></span>
                                    <span class="surgewave-mono">@string.Join(", ", p.Isr)</span>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>
}

@code {
    [Parameter]
    public int BrokerId { get; set; }

    private bool _loading = true;
    private string? _error;
    private BrokerInfo? _broker;
    private bool _isOnline = true;
    private List<BrokerPartitionInfo> _leaderPartitions = [];
    private List<BrokerPartitionInfo> _replicaPartitions = [];

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new("Brokers", "/brokers"),
            new($"Broker {BrokerId}", null, true)
        ];

        ClusterState.OnChange += async () =>
        {
            await LoadBrokerAsync();
            StateHasChanged();
        };
        await LoadBrokerAsync();
    }

    private async Task LoadBrokerAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var clusterId = ClusterState.SelectedClusterId;
            var brokers = await ApiClient.ListBrokersAsync(clusterId);
            _broker = brokers.FirstOrDefault(b => b.BrokerId == BrokerId);

            if (_broker == null)
            {
                _error = $"Broker {BrokerId} not found";
            }
            else
            {
                // Check broker health
                try
                {
                    var health = await ApiClient.GetHealthDetailsAsync();
                    _isOnline = health?.Status == "Healthy";
                }
                catch
                {
                    _isOnline = false;
                }

                // Load partition leadership info
                if (clusterId != null)
                {
                    await LoadPartitionLeadershipAsync(clusterId);
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPartitionLeadershipAsync(string clusterId)
    {
        _leaderPartitions = [];
        _replicaPartitions = [];

        try
        {
            var topics = await ApiClient.ListTopicsAsync(clusterId, includeInternal: true);

            foreach (var topic in topics)
            {
                var topicDetails = await ApiClient.DescribeTopicAsync(topic.Name, clusterId);
                if (topicDetails?.Partitions == null) continue;

                foreach (var partition in topicDetails.Partitions)
                {
                    // Check if this broker is involved in this partition
                    if (!partition.Replicas.Contains(BrokerId)) continue;

                    var info = new BrokerPartitionInfo(
                        topic.Name,
                        partition.PartitionId,
                        partition.Leader == BrokerId,
                        partition.Replicas.ToList(),
                        partition.Isr.ToList());

                    if (info.IsLeader)
                        _leaderPartitions.Add(info);
                    else
                        _replicaPartitions.Add(info);
                }
            }
        }
        catch
        {
            // Ignore errors loading partition data
        }
    }

    private record BrokerPartitionInfo(
        string Topic,
        int PartitionId,
        bool IsLeader,
        List<int> Replicas,
        List<int> Isr);
}
