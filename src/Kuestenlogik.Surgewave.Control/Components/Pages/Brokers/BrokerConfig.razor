@page "/brokers/{BrokerId:int}/config"
@using Kuestenlogik.Surgewave.Control.Models
@using Kuestenlogik.Surgewave.Control.Services
@inject ISurgewaveApiClient ApiClient
@inject NotificationState Notification
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ClusterState ClusterState

<PageTitle>Broker @BrokerId Config - Surgewave Control</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <PageHead Title="@($"Broker {BrokerId} Configuration")" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_configs.Count configs | @_configs.Count(c => c.IsModified) modified from default
        </MudText>
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ExportConfigAsync"
                   StartIcon="@Icons.Material.Filled.Download">Export</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync"
                   StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading">
            Refresh
        </MudButton>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

@* ===== FILTERS ===== *@
<MudPaper Elevation="2" Class="pa-3 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="5">
            <MudTextField T="string" @bind-Value="_search" Placeholder="Search configs..."
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="string" @bind-Value="_filterCategory" Label="Category" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Clearable="true">
                @foreach (var cat in _categories.OrderBy(c => c))
                {
                    <MudSelectItem Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect T="string" @bind-Value="_filterSource" Label="Source" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Clearable="true">
                <MudSelectItem Value="@("modified")">Modified Only</MudSelectItem>
                <MudSelectItem Value="@("default")">Default Only</MudSelectItem>
                <MudSelectItem Value="@("readonly")">Read-Only</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="mt-1">
                @FilteredConfigs.Count() of @_configs.Count
            </MudChip>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ===== CONFIG TABLE ===== *@
<MudTable Items="FilteredConfigs" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
          RowsPerPage="25" SortLabel="Sort by">
    <ColGroup>
        <col style="width: 35%;" />
        <col style="width: 25%;" />
        <col style="width: 15%;" />
        <col style="width: 10%;" />
        <col style="width: 10%;" />
        <col style="width: 5%;" />
    </ColGroup>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="@_sortByKey">Key</MudTableSortLabel></MudTh>
        <MudTh>Value</MudTh>
        <MudTh>Default</MudTh>
        <MudTh><MudTableSortLabel SortBy="@_sortBySource">Source</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="@_sortByCategory">Category</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Key">
            <div>
                <code style="font-size: 13px;">@context.Key</code>
                @if (context.IsReadOnly)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                }
                @if (context.IsSensitive)
                {
                    <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" Color="Color.Warning" Class="ml-1" />
                }
            </div>
            @if (context.Documentation != null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="max-width: 350px;">
                    @context.Documentation
                </MudText>
            }
        </MudTd>
        <MudTd DataLabel="Value">
            @if (context.IsSensitive)
            {
                <MudText Typo="Typo.body2" Style="font-family: monospace;">********</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2" Style="font-family: monospace; word-break: break-all;"
                         Color="@(context.IsModified ? Color.Warning : Color.Default)">
                    @(context.Value.Length > 60 ? context.Value[..57] + "..." : context.Value)
                </MudText>
            }
        </MudTd>
        <MudTd DataLabel="Default">
            @if (context.DefaultValue != null && context.DefaultValue != context.Value)
            {
                <MudText Typo="Typo.caption" Style="font-family: monospace; text-decoration: line-through;" Color="Color.Secondary">
                    @(context.DefaultValue.Length > 40 ? context.DefaultValue[..37] + "..." : context.DefaultValue)
                </MudText>
            }
        </MudTd>
        <MudTd DataLabel="Source">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetSourceColor(context.Source)">
                @context.Source
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Category">
            <MudText Typo="Typo.caption">@context.Category</MudText>
        </MudTd>
        <MudTd DataLabel="Actions">
            @if (!context.IsReadOnly)
            {
                <AuthorizeView Policy="@SurgewavePolicies.TopicsManage" Context="authContext">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => EditConfigAsync(context))" />
                </AuthorizeView>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@* ===== EDIT DIALOG ===== *@
<MudDialog @bind-Visible="_editDialogVisible" Options="@_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Edit Configuration
        </div>
    </TitleContent>
    <DialogContent>
        @if (_editingConfig != null)
        {
            <MudTextField T="string" Value="@_editingConfig.Key" Label="Key" ReadOnly="true"
                          Variant="Variant.Outlined" Class="mb-3" />
            @if (_editingConfig.Documentation != null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">@_editingConfig.Documentation</MudAlert>
            }
            <MudTextField T="string" @bind-Value="_editValue" Label="Value" Variant="Variant.Outlined"
                          Class="mb-3" />
            @if (_editingConfig.DefaultValue != null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Default: <code>@_editingConfig.DefaultValue</code>
                </MudText>
                @if (_editValue != _editingConfig.DefaultValue)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                               OnClick="@(() => _editValue = _editingConfig.DefaultValue)">
                        Reset to default
                    </MudButton>
                }
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _editDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveConfigAsync"
                   Disabled="@(_editValue == _editingConfig?.Value)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public int BrokerId { get; set; }

    private bool _loading = true;
    private List<BrokerConfigEntry> _configs = [];
    private string _search = "";
    private string? _filterCategory;
    private string? _filterSource;

    // Edit state
    private bool _editDialogVisible;
    private BrokerConfigEntry? _editingConfig;
    private string _editValue = "";

    private List<BreadcrumbItem> _breadcrumbs = [];
    private static readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private static readonly Func<BrokerConfigEntry, object> _sortByKey = x => x.Key;
    private static readonly Func<BrokerConfigEntry, object> _sortBySource = x => x.Source.ToString();
    private static readonly Func<BrokerConfigEntry, object> _sortByCategory = x => x.Category;

    private HashSet<string> _categories => _configs.Select(c => c.Category).ToHashSet();

    private IEnumerable<BrokerConfigEntry> FilteredConfigs
    {
        get
        {
            var items = _configs.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_search))
                items = items.Where(c => c.Key.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                                         c.Value.Contains(_search, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(_filterCategory))
                items = items.Where(c => c.Category == _filterCategory);

            if (_filterSource == "modified")
                items = items.Where(c => c.IsModified);
            else if (_filterSource == "default")
                items = items.Where(c => !c.IsModified);
            else if (_filterSource == "readonly")
                items = items.Where(c => c.IsReadOnly);

            return items.OrderBy(c => c.Category).ThenBy(c => c.Key);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new("Brokers", "/brokers"),
            new($"Broker {BrokerId}", $"/brokers/{BrokerId}"),
            new("Configuration", null, true)
        ];

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _configs = (await ApiClient.GetBrokerConfigsAsync(BrokerId, ClusterState.SelectedClusterId)).ToList();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to load configs: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void EditConfigAsync(BrokerConfigEntry config)
    {
        _editingConfig = config;
        _editValue = config.Value;
        _editDialogVisible = true;
    }

    private async Task SaveConfigAsync()
    {
        if (_editingConfig == null || _editValue == _editingConfig.Value) return;

        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Configuration Change",
            $"Change '{_editingConfig.Key}' from '{_editingConfig.Value}' to '{_editValue}'?\n\nThis may require a broker restart to take effect.",
            yesText: "Apply", cancelText: "Cancel");

        if (confirmed == true)
        {
            var success = await ApiClient.AlterBrokerConfigAsync(BrokerId, _editingConfig.Key, _editValue, ClusterState.SelectedClusterId);
            if (success)
            {
                _editingConfig.Value = _editValue;
                _editingConfig.Source = ConfigSource.DynamicBroker;
                Notification.ShowSuccess($"Configuration '{_editingConfig.Key}' updated");
                _editDialogVisible = false;
            }
            else
            {
                Notification.ShowError("Failed to update configuration");
            }
        }
    }

    private async Task ExportConfigAsync()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(
            _configs.Where(c => !c.IsSensitive).ToDictionary(c => c.Key, c => c.Value),
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        Notification.ShowInfo($"Exported {_configs.Count(c => !c.IsSensitive)} config entries");
    }

    private static Color GetSourceColor(ConfigSource source) => source switch
    {
        ConfigSource.DynamicBroker => Color.Primary,
        ConfigSource.DynamicCluster => Color.Info,
        ConfigSource.StaticBroker => Color.Warning,
        ConfigSource.DynamicTopic => Color.Tertiary,
        _ => Color.Default
    };
}
