@page "/clusters"
@using Kuestenlogik.Surgewave.Control.Models
@using Kuestenlogik.Surgewave.Control.Services
@inject ISurgewaveApiClient ApiClient
@inject NavigationManager Navigation
@inject NotificationState Notification
@inject ClusterState ClusterState

<PageTitle>Cluster Overview - Surgewave Control</PageTitle>

<PageHead Title="Cluster Overview"
          Subtitle="All clusters at a glance — health, metrics, and quick-switch.">
    <Actions>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default"
                       Size="Size.Small" OnClick="LoadDataAsync" Disabled="_loading" />
    </Actions>
</PageHead>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<SummaryStrip>
    <Stat Label="Clusters" Value="@_clusters.Count.ToString()" />
    <Stat Label="Total brokers" Value="@_clusters.Sum(c => c.BrokerCount).ToString()" />
    <Stat Label="Total topics" Value="@_clusters.Sum(c => c.TopicCount).ToString()" />
    <Stat Label="Total throughput"
          Value="@($"{_clusters.Sum(c => c.ThroughputMessagesPerSec):F0} msg/s")" />
</SummaryStrip>

@* ===== CLUSTER CARDS ===== *@
@if (_clusters.Count == 0 && !_loading)
{
    <MudAlert Severity="Severity.Info">
        No clusters configured. The default cluster will appear once connected.
    </MudAlert>
}

<MudGrid>
    @foreach (var cluster in _clusters)
    {
        var isSelected = cluster.ClusterId == ClusterState.SelectedClusterId ||
                         (ClusterState.SelectedClusterId == null && cluster == _clusters.First());
        <MudItem xs="12" md="6" lg="4">
            <MudCard Elevation="0" Class="@(isSelected ? "surgewave-cluster-card--active" : "")"
                     Style="cursor: pointer;"
                     @onclick="@(() => SwitchCluster(cluster))">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@cluster.DisplayName</MudText>
                        <span class="surgewave-mono">@cluster.ClusterId</span>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <span class="surgewave-status @GetHealthStatusClass(cluster.Status)">
                            <span class="surgewave-status-dot"></span>
                            @(isSelected ? $"Active · {cluster.Status}" : cluster.Status)
                        </span>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Brokers</MudText></td>
                                <td><span class="surgewave-mono">@cluster.BrokerCount</span></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Topics</MudText></td>
                                <td><span class="surgewave-mono">@cluster.TopicCount</span></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Partitions</MudText></td>
                                <td><span class="surgewave-mono">@cluster.PartitionCount</span></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Consumer Groups</MudText></td>
                                <td><span class="surgewave-mono">@cluster.ConsumerGroupCount</span></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Controller</MudText></td>
                                <td><span class="surgewave-mono">Broker @cluster.ControllerId</span></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Throughput</MudText></td>
                                <td><span class="surgewave-mono">@cluster.ThroughputMessagesPerSec.ToString("F0") msg/s</span></td>
                            </tr>
                            @if (cluster.RaftEnabled)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Secondary">Raft</MudText></td>
                                    <td>
                                        <span class="surgewave-status surgewave-status--info">
                                            <span class="surgewave-status-dot"></span>
                                            @(cluster.RaftState ?? "Unknown")
                                        </span>
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Last checked</MudText></td>
                                <td><span class="surgewave-mono">@cluster.LastChecked.ToString("HH:mm:ss")</span></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                               OnClick="@(() => Navigation.NavigateTo("/brokers"))"
                               StartIcon="@Icons.Material.Filled.Dns">
                        Brokers
                    </MudButton>
                    <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                               OnClick="@(() => Navigation.NavigateTo("/health"))"
                               StartIcon="@Icons.Material.Filled.MonitorHeart">
                        Health
                    </MudButton>
                    <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                               OnClick="@(() => Navigation.NavigateTo("/topics"))"
                               StartIcon="@Icons.Material.Filled.Topic">
                        Topics
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private bool _loading = true;
    private List<ClusterOverviewInfo> _clusters = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // Load the default/current cluster
            var clusterInfo = await ApiClient.GetClusterInfoAsync();
            var healthDetails = await ApiClient.GetHealthDetailsAsync();

            if (clusterInfo != null)
            {
                var groups = await ApiClient.ListConsumerGroupsAsync();

                var overview = new ClusterOverviewInfo
                {
                    ClusterId = clusterInfo.ClusterId,
                    DisplayName = $"Cluster {clusterInfo.ClusterId[..Math.Min(8, clusterInfo.ClusterId.Length)]}",
                    Status = healthDetails?.Status ?? "Unknown",
                    BrokerCount = clusterInfo.BrokerCount,
                    TopicCount = clusterInfo.TopicCount,
                    PartitionCount = clusterInfo.PartitionCount,
                    ConsumerGroupCount = groups.Count,
                    ControllerId = clusterInfo.ControllerId,
                    RaftEnabled = healthDetails?.RaftEnabled ?? false,
                    RaftState = healthDetails?.RaftState,
                    ThroughputMessagesPerSec = SimThroughput(clusterInfo.ClusterId),
                    LastChecked = DateTimeOffset.UtcNow
                };

                _clusters = [overview];
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Failed to load clusters: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void SwitchCluster(ClusterOverviewInfo cluster)
    {
        ClusterState.SelectedClusterId = cluster.ClusterId;
        Notification.ShowSuccess($"Switched to cluster '{cluster.DisplayName}'");
    }

    private static double SimThroughput(string clusterId)
    {
        return Math.Abs(clusterId.GetHashCode() % 10000) + 500.0;
    }

    private static Color GetHealthColor(string status) => status switch
    {
        "Healthy" => Color.Success,
        "Degraded" => Color.Warning,
        "Unhealthy" => Color.Error,
        _ => Color.Default
    };

    private static string GetHealthStatusClass(string status) => status switch
    {
        "Healthy" => "surgewave-status--ok",
        "Degraded" => "surgewave-status--warn",
        "Unhealthy" => "surgewave-status--error",
        _ => ""
    };
}

<style>
    .surgewave-cluster-card--active {
        border-color: var(--mud-palette-primary) !important;
        box-shadow: 0 0 0 1px var(--mud-palette-primary) !important;
    }
</style>
