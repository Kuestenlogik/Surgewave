@page "/alerts"
@using Kuestenlogik.Surgewave.Control.Services.Alerting
@inject ILocalStorageService LocalStorage
@inject IAlertingService Alerting
@inject NotificationState Notification
@implements IDisposable

<PageTitle>Alerts - Surgewave Control</PageTitle>

<PageHead Title="Alert Management"
          Subtitle="Active alerts, rules, and notification channels — evaluated server-side, alerts fire without an open browser." />

<SummaryStrip>
    <Stat Label="Active">
        @{
            var active = _activeAlerts.Count(a => a.AcknowledgedAt == null);
        }
        <span class="surgewave-status @(active > 0 ? "surgewave-status--error" : "surgewave-status--ok")">
            <span class="surgewave-status-dot"></span>
            @active
        </span>
    </Stat>
    <Stat Label="Critical">
        <span class="surgewave-status surgewave-status--error">
            <span class="surgewave-status-dot"></span>
            @_activeAlerts.Count(a => a.Severity == AlertSeverity.Critical)
        </span>
    </Stat>
    <Stat Label="Warning">
        <span class="surgewave-status surgewave-status--warn">
            <span class="surgewave-status-dot"></span>
            @_activeAlerts.Count(a => a.Severity == AlertSeverity.Warning)
        </span>
    </Stat>
    <Stat Label="Info">
        <span class="surgewave-status surgewave-status--info">
            <span class="surgewave-status-dot"></span>
            @_activeAlerts.Count(a => a.Severity == AlertSeverity.Info)
        </span>
    </Stat>
    <Stat Label="Rules" Value="@_rules.Count.ToString()" />
    <Stat Label="Last evaluation"
          Value="@(Alerting.LastEvaluatedAt?.ToLocalTime().ToString("HH:mm:ss") ?? "—")" />
</SummaryStrip>

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="true" PanelClass="pt-4" Class="mb-4">
    @* Tab 1: Active Alerts *@
    <MudTabPanel Text="Active Alerts" Icon="@Icons.Material.Filled.NotificationsActive"
                 BadgeData="@_activeAlerts.Count(a => a.AcknowledgedAt == null)"
                 BadgeColor="Color.Error">
        @if (_activeAlerts.Count == 0)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                No active alerts. All systems operational.
            </MudAlert>
        }
        else
        {
            <div class="d-flex gap-2 mb-3">
                <MudChip T="string" Color="Color.Error" Size="Size.Small">
                    @_activeAlerts.Count(a => a.Severity == AlertSeverity.Critical) Critical
                </MudChip>
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                    @_activeAlerts.Count(a => a.Severity == AlertSeverity.Warning) Warning
                </MudChip>
                <MudChip T="string" Color="Color.Info" Size="Size.Small">
                    @_activeAlerts.Count(a => a.Severity == AlertSeverity.Info) Info
                </MudChip>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                           OnClick="AcknowledgeAll">
                    Acknowledge All
                </MudButton>
            </div>

            @foreach (var alert in _activeAlerts.OrderByDescending(a => a.Severity).ThenByDescending(a => a.FiredAt))
            {
                <MudCard Elevation="1" Class="mb-2" Style="@($"border-left: 4px solid {GetSeverityBorderColor(alert.Severity)};")">
                    <MudCardContent Class="pa-3">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@GetSeverityIcon(alert.Severity)" Color="@GetSeverityColor(alert.Severity)" />
                            <div style="flex: 1;">
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.subtitle2">@alert.RuleName</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@GetAlertTypeColor(alert.Type)">
                                        @alert.Type
                                    </MudChip>
                                    @if (alert.AcknowledgedAt != null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                            ACK by @alert.AcknowledgedBy
                                        </MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.body2">@alert.Message</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Fired @alert.FiredAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                    | Value: @alert.CurrentValue.ToString("N1") (Threshold: @alert.Threshold.ToString("N1"))
                                </MudText>
                            </div>
                            @if (alert.AcknowledgedAt == null)
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => AcknowledgeAlert(alert))">
                                    ACK
                                </MudButton>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Done" Size="Size.Small" Color="Color.Success"
                                           OnClick="@(() => ResolveAlert(alert))" />
                        </div>
                    </MudCardContent>
                </MudCard>
            }
        }
    </MudTabPanel>

    @* Tab 2: Alert Rules *@
    <MudTabPanel Text="Rules" Icon="@Icons.Material.Filled.Rule">
        <div class="d-flex justify-end gap-2 mb-3">
            <MudMenu Label="Add from Template" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome"
                     Color="Color.Secondary">
                <MudMenuItem OnClick="@(() => AddTemplateRule("High Consumer Lag", AlertRuleType.ConsumerLag, 10000))">
                    High Consumer Lag (&gt; 10K)
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => AddTemplateRule("Critical Consumer Lag", AlertRuleType.ConsumerLag, 100000, AlertSeverity.Critical))">
                    Critical Consumer Lag (&gt; 100K)
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => AddTemplateRule("High Error Rate", AlertRuleType.ErrorRate, 10))">
                    High Error Rate (&gt; 10/sec)
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => AddTemplateRule("High Latency (P99)", AlertRuleType.HighLatency, 100))">
                    High P99 Latency (&gt; 100ms)
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => AddTemplateRule("Low Throughput", AlertRuleType.LowThroughput, 0))">
                    Low Throughput (0 msg/s)
                </MudMenuItem>
            </MudMenu>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddNewRule">
                New Rule
            </MudButton>
        </div>

        @if (_rules.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No alert rules configured. Add rules using the templates or create custom rules.
            </MudAlert>
        }
        else
        {
            @foreach (var rule in _rules)
            {
                <MudCard Elevation="1" Class="mb-2">
                    <MudCardContent Class="pa-3">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="rule.Name" Label="Name" Variant="Variant.Text"
                                              Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudSelect @bind-Value="rule.Type" Label="Type" Variant="Variant.Text" Margin="Margin.Dense">
                                    @foreach (AlertRuleType type in Enum.GetValues<AlertRuleType>())
                                    {
                                        <MudSelectItem Value="@type">@type</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudSelect @bind-Value="rule.Severity" Label="Severity" Variant="Variant.Text" Margin="Margin.Dense">
                                    @foreach (AlertSeverity sev in Enum.GetValues<AlertSeverity>())
                                    {
                                        <MudSelectItem Value="@sev">@sev</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField @bind-Value="rule.Threshold" Label="Threshold" Variant="Variant.Text"
                                                 Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="1">
                                <MudSwitch T="bool" @bind-Value="rule.Enabled" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" md="2" Class="d-flex align-center justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteRule(rule))" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                       OnClick="SaveRulesAsync">
                Save Rules
            </MudButton>
        }
    </MudTabPanel>

    @* Tab 3: Notification Channels *@
    <MudTabPanel Text="Channels" Icon="@Icons.Material.Filled.Notifications">
        <div class="d-flex justify-end mb-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddChannel">
                Add Channel
            </MudButton>
        </div>

        @if (_channels.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No notification channels configured. Alerts will only appear in the UI.
            </MudAlert>
        }
        else
        {
            @foreach (var channel in _channels)
            {
                <MudCard Elevation="1" Class="mb-2">
                    <MudCardContent Class="pa-3">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="channel.Name" Label="Name" Variant="Variant.Text"
                                              Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudSelect @bind-Value="channel.Type" Label="Type" Variant="Variant.Text" Margin="Margin.Dense">
                                    @foreach (NotificationChannelType type in Enum.GetValues<NotificationChannelType>())
                                    {
                                        <MudSelectItem Value="@type">@type</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="@GetChannelUrl(channel)" Label="@GetChannelUrlLabel(channel.Type)"
                                              Variant="Variant.Text" Margin="Margin.Dense"
                                              Placeholder="@GetChannelPlaceholder(channel.Type)"
                                              ValueChanged="@((string v) => SetChannelUrl(channel, v))" />
                            </MudItem>
                            <MudItem xs="12" md="1">
                                <MudSwitch T="bool" @bind-Value="channel.Enabled" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" md="2" Class="d-flex align-center justify-end gap-1">
                                <MudTooltip Text="Send Test">
                                    <MudIconButton Icon="@Icons.Material.Filled.Send" Size="Size.Small"
                                                   Color="Color.Info" OnClick="@(() => TestChannel(channel))" />
                                </MudTooltip>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteChannel(channel))" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                       OnClick="SaveChannelsAsync">
                Save Channels
            </MudButton>
        }
    </MudTabPanel>

    @* Tab 4: Alert History *@
    <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
        @if (_alertHistory.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No alert history.</MudAlert>
        }
        else
        {
            <MudTable Items="@_alertHistory.OrderByDescending(a => a.FiredAt)" Dense="true" Hover="true" Striped="true"
                      T="AlertEvent" RowsPerPage="20">
                <HeaderContent>
                    <MudTh>Severity</MudTh>
                    <MudTh>Rule</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Message</MudTh>
                    <MudTh>Fired</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudIcon Icon="@GetSeverityIcon(context.Severity)" Color="@GetSeverityColor(context.Severity)" Size="Size.Small" />
                    </MudTd>
                    <MudTd>@context.RuleName</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetAlertTypeColor(context.Type)">@context.Type</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@Truncate(context.Message, 60)</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">@context.FiredAt.ToLocalTime().ToString("MM-dd HH:mm:ss")</MudText>
                    </MudTd>
                    <MudTd>
                        @if (context.IsResolved)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Resolved</MudChip>
                        }
                        else if (context.AcknowledgedAt != null)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Acknowledged</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Active</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>

            <MudButton Variant="Variant.Text" Color="Color.Secondary" Class="mt-3"
                       OnClick="ClearHistory" StartIcon="@Icons.Material.Filled.DeleteSweep">
                Clear History
            </MudButton>
        }
    </MudTabPanel>
</MudTabs>

@code {
    private int _activeTab;

    private List<AlertRule> _rules = [];
    private List<AlertEvent> _activeAlerts = [];
    private List<AlertEvent> _alertHistory = [];
    private List<NotificationChannel> _channels = [];

    // Legacy browser-storage keys — read once to migrate pre-#38 configs to the server.
    private const string RulesStorageKey = "surgewave-alert-rules";
    private const string AlertsStorageKey = "surgewave-alert-events";
    private const string ChannelsStorageKey = "surgewave-alert-channels";

    protected override void OnInitialized()
    {
        Alerting.Changed += OnAlertingChanged;
        ReloadConfig();
        ReloadAlerts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await MigrateLocalStorageAsync();
    }

    // Rules and channels are editing buffers: the Rules/Channels tabs mutate
    // them in place and only persist on the explicit Save buttons. Reload them
    // solely on our own load/save — never from a background Changed event, which
    // would silently discard the user's unsaved edits.
    private void ReloadConfig()
    {
        _rules = [.. Alerting.GetRules()];
        _channels = [.. Alerting.GetChannels()];
    }

    private void ReloadAlerts()
    {
        _alertHistory = [.. Alerting.GetEvents()];
        _activeAlerts = _alertHistory.Where(a => !a.IsResolved).ToList();
    }

    private void OnAlertingChanged() => _ = InvokeAsync(() =>
    {
        // Background evaluation ticks and cross-tab acks land here; refresh only
        // the read-only alert lists (and the LastEvaluatedAt stat), leaving the
        // rule/channel editing buffers untouched.
        ReloadAlerts();
        StateHasChanged();
    });

    private async Task MigrateLocalStorageAsync()
    {
        try
        {
            if (_rules.Count > 0 || _channels.Count > 0)
                return;

            var legacyRules = await LocalStorage.GetItemAsync<List<AlertRule>>(RulesStorageKey) ?? [];
            var legacyChannels = await LocalStorage.GetItemAsync<List<NotificationChannel>>(ChannelsStorageKey) ?? [];
            if (legacyRules.Count == 0 && legacyChannels.Count == 0)
                return;

            if (legacyRules.Count > 0)
                Alerting.SaveRules(legacyRules);
            if (legacyChannels.Count > 0)
                Alerting.SaveChannels(legacyChannels);

            await LocalStorage.RemoveItemAsync(RulesStorageKey);
            await LocalStorage.RemoveItemAsync(ChannelsStorageKey);
            await LocalStorage.RemoveItemAsync(AlertsStorageKey);

            ReloadConfig();
            ReloadAlerts();
            Notification.ShowSuccess("Migrated browser-stored alert rules to server-side storage");
            StateHasChanged();
        }
        catch
        {
            // LocalStorage unavailable (e.g. during prerender) — nothing to migrate.
        }
    }

    private void AddNewRule()
    {
        _rules.Add(new AlertRule
        {
            Name = $"Rule {_rules.Count + 1}",
            Type = AlertRuleType.ConsumerLag,
            Severity = AlertSeverity.Warning,
            Threshold = 1000,
            Enabled = true
        });
    }

    private void AddTemplateRule(string name, AlertRuleType type, double threshold,
        AlertSeverity severity = AlertSeverity.Warning)
    {
        _rules.Add(new AlertRule
        {
            Name = name,
            Type = type,
            Severity = severity,
            Threshold = threshold,
            Enabled = true
        });
    }

    private void DeleteRule(AlertRule rule) => _rules.Remove(rule);

    private Task SaveRulesAsync()
    {
        Alerting.SaveRules(_rules);
        Notification.ShowSuccess("Alert rules saved");
        return Task.CompletedTask;
    }

    private void AcknowledgeAlert(AlertEvent alert)
        => Alerting.Acknowledge(alert.Id, "admin");

    private void AcknowledgeAll()
        => Alerting.AcknowledgeAll("admin");

    private void ResolveAlert(AlertEvent alert)
        => Alerting.Resolve(alert.Id);

    private void ClearHistory()
    {
        Alerting.ClearResolvedHistory();
        Notification.ShowSuccess("Alert history cleared");
    }

    // --- Notification Channels ---

    private void AddChannel()
    {
        _channels.Add(new NotificationChannel
        {
            Name = $"Channel {_channels.Count + 1}",
            Type = NotificationChannelType.Slack,
            Enabled = true
        });
    }

    private void DeleteChannel(NotificationChannel channel) => _channels.Remove(channel);

    private Task SaveChannelsAsync()
    {
        Alerting.SaveChannels(_channels);
        Notification.ShowSuccess("Notification channels saved");
        return Task.CompletedTask;
    }

    private async Task TestChannel(NotificationChannel channel)
    {
        if (await Alerting.SendTestAsync(channel))
            Notification.ShowSuccess($"Test notification sent to '{channel.Name}' ({channel.Type})");
        else
            Notification.ShowError($"Test notification to '{channel.Name}' failed — check the channel configuration");
    }

    private static string GetChannelUrl(NotificationChannel channel) =>
        channel.Config.GetValueOrDefault("url", "");

    private static void SetChannelUrl(NotificationChannel channel, string value) =>
        channel.Config["url"] = value;

    private static string GetChannelUrlLabel(NotificationChannelType type) => type switch
    {
        NotificationChannelType.Slack => "Webhook URL",
        NotificationChannelType.MicrosoftTeams => "Webhook URL",
        NotificationChannelType.PagerDuty => "Integration Key",
        NotificationChannelType.Email => "SMTP Server / Recipients",
        NotificationChannelType.Webhook => "Webhook URL",
        _ => "URL"
    };

    private static string GetChannelPlaceholder(NotificationChannelType type) => type switch
    {
        NotificationChannelType.Slack => "https://hooks.slack.com/services/...",
        NotificationChannelType.MicrosoftTeams => "https://outlook.office.com/webhook/...",
        NotificationChannelType.PagerDuty => "your-integration-key",
        NotificationChannelType.Email => "smtp://host:port;to@example.com",
        NotificationChannelType.Webhook => "https://your-webhook.example.com/alerts",
        _ => ""
    };

    // --- UI Helpers ---

    private static Color GetSeverityColor(AlertSeverity severity) => severity switch
    {
        AlertSeverity.Critical => Color.Error,
        AlertSeverity.Warning => Color.Warning,
        AlertSeverity.Info => Color.Info,
        _ => Color.Default
    };

    private static string GetSeverityBorderColor(AlertSeverity severity) => severity switch
    {
        AlertSeverity.Critical => "#f44336",
        AlertSeverity.Warning => "#ff9800",
        AlertSeverity.Info => "#2196f3",
        _ => "#9e9e9e"
    };

    private static string GetSeverityIcon(AlertSeverity severity) => severity switch
    {
        AlertSeverity.Critical => Icons.Material.Filled.Error,
        AlertSeverity.Warning => Icons.Material.Filled.Warning,
        AlertSeverity.Info => Icons.Material.Filled.Info,
        _ => Icons.Material.Filled.Info
    };

    private static Color GetAlertTypeColor(AlertRuleType type) => type switch
    {
        AlertRuleType.ConsumerLag => Color.Warning,
        AlertRuleType.ErrorRate => Color.Error,
        AlertRuleType.BrokerDown => Color.Error,
        AlertRuleType.HighLatency => Color.Warning,
        AlertRuleType.UnderReplicatedPartitions => Color.Error,
        _ => Color.Default
    };

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..maxLength] + "...";

    public void Dispose() => Alerting.Changed -= OnAlertingChanged;
}
