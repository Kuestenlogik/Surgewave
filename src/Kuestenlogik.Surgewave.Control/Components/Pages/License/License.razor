@page "/license"
@using Kuestenlogik.Surgewave.Control.Models.License
@using Kuestenlogik.Surgewave.Control.Services
@inject ILicenseApiClient LicenseClient

<PageTitle>License - Surgewave Control</PageTitle>

<div class="surgewave-page-head">
    <div>
        <h1 class="surgewave-page-head-title">License</h1>
        <p class="surgewave-page-head-subtitle">
            Edition, licensee, expiry and the per-plugin licence requirement matrix.
        </p>
    </div>
</div>

@if (_status is null)
{
    <MudPaper Class="surgewave-surface">
        <MudText Typo="Typo.body2">Loading license information…</MudText>
    </MudPaper>
}
else
{
    @* Summary strip — clean horizontal stats instead of a 3-card grid. *@
    <div class="surgewave-summary-strip">
        <div class="surgewave-stat">
            <span class="surgewave-stat-label">Edition</span>
            <span class="surgewave-stat-value">
                <span class="surgewave-status @EditionStatusClass">
                    <span class="surgewave-status-dot"></span>
                    @_status.Edition
                </span>
            </span>
        </div>
        <div class="surgewave-stat">
            <span class="surgewave-stat-label">Licensed to</span>
            <span class="surgewave-stat-value @(string.IsNullOrEmpty(_status.LicensedTo) ? "surgewave-stat-value--muted" : "")">
                @(string.IsNullOrEmpty(_status.LicensedTo) ? "—" : _status.LicensedTo)
            </span>
        </div>
        <div class="surgewave-stat">
            <span class="surgewave-stat-label">Expires</span>
            <span class="surgewave-stat-value @ExpiryValueClass">
                @ExpiryDisplay
            </span>
        </div>
        <div class="surgewave-stat">
            <span class="surgewave-stat-label">Plugins discovered</span>
            <span class="surgewave-stat-value">@_plugins.Count</span>
        </div>
    </div>

    @if (!_status.HasProvider)
    {
        <MudPaper Class="surgewave-surface mb-4">
            <MudText Typo="Typo.body2">
                No <span class="surgewave-mono">ILicenseProvider</span> is registered.
                The broker runs in community mode — plugins with
                <span class="surgewave-mono">RequiresLicense = false</span> load
                unconditionally; plugins that require a licence are skipped with a warning at startup.
            </MudText>
        </MudPaper>
    }

    <div class="surgewave-section-title">Discovered broker plugins</div>

    <MudPaper Class="surgewave-surface" Style="padding: 0;">
        @if (_plugins.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="pa-6">No broker plugins were discovered.</MudText>
        }
        else
        {
            <MudTable Items="_plugins" Dense="true" Hover="true" Bordered="false" Elevation="0">
                <HeaderContent>
                    <MudTh>Plugin</MudTh>
                    <MudTh>Feature ID</MudTh>
                    <MudTh>Licence</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Plugin">
                        <strong>@context.DisplayName</strong>
                    </MudTd>
                    <MudTd DataLabel="Feature ID">
                        <span class="surgewave-mono">@context.FeatureId</span>
                    </MudTd>
                    <MudTd DataLabel="Licence">
                        @if (!context.RequiresLicense)
                        {
                            <span class="surgewave-status">
                                <span class="surgewave-status-dot"></span>
                                Community
                            </span>
                        }
                        else if (context.IsLicensed)
                        {
                            <span class="surgewave-status surgewave-status--ok">
                                <span class="surgewave-status-dot"></span>
                                Licensed
                            </span>
                        }
                        else
                        {
                            <span class="surgewave-status surgewave-status--error">
                                <span class="surgewave-status-dot"></span>
                                Not licensed
                            </span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive)
                        {
                            <span class="surgewave-status surgewave-status--ok">
                                <span class="surgewave-status-dot"></span>
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="surgewave-status surgewave-status--idle">
                                <span class="surgewave-status-dot"></span>
                                Inactive
                            </span>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@code {
    private LicenseStatusModel? _status;
    private IReadOnlyList<LicensePluginRowModel> _plugins = [];

    protected override async Task OnInitializedAsync()
    {
        _status = await LicenseClient.GetStatusAsync()
                  ?? new LicenseStatusModel("Community", null, null, false);
        _plugins = await LicenseClient.GetPluginsAsync();
    }

    private string EditionStatusClass => _status?.Edition == "Enterprise"
        ? "surgewave-status--info"
        : "surgewave-status--idle";

    private string ExpiryValueClass
    {
        get
        {
            if (_status?.ExpiresAt is null) return "surgewave-stat-value--muted";
            return ""; // colored via status-dot variant below if we add one later
        }
    }

    private string ExpiryDisplay
    {
        get
        {
            if (_status?.ExpiresAt is null) return "—";
            var d = _status.ExpiresAt.Value;
            var days = (d - DateTimeOffset.UtcNow).TotalDays;
            return days < 0
                ? $"{d:yyyy-MM-dd} (expired)"
                : days < 30
                    ? $"{d:yyyy-MM-dd} (in {(int)days}d)"
                    : $"{d:yyyy-MM-dd}";
        }
    }
}
