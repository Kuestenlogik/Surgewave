@using Kuestenlogik.Surgewave.Control.Models.Chat
@inject IChatApiClient ChatApi
@inject IJSRuntime JS

<MudDrawer Open="IsOpen" OpenChanged="OnOpenChanged" Anchor="Anchor.End" Elevation="4" Width="420px"
           Variant="DrawerVariant.Temporary" Class="chat-drawer">
    <MudDrawerHeader Class="d-flex align-center justify-space-between pa-3">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Pipeline Chat</MudText>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="@(() => IsOpenChanged.InvokeAsync(false))" />
    </MudDrawerHeader>

    <div class="chat-session-bar pa-2">
        <MudGrid Spacing="1">
            <MudItem xs="9">
                <MudSelect T="string" Value="_selectedSessionId" ValueChanged="OnSessionSelected"
                           Label="Session" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                    @foreach (var session in _sessions)
                    {
                        <MudSelectItem Value="@session.SessionId">
                            @session.SessionId[..Math.Min(8, session.SessionId.Length)]... (@session.MessageCount msgs)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="3" Class="d-flex align-center">
                <MudTooltip Text="New session">
                    <MudIconButton Icon="@Icons.Material.Filled.AddComment" Size="Size.Small"
                                   Color="Color.Primary" OnClick="StartNewSession" />
                </MudTooltip>
                <MudTooltip Text="Delete session">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                   Color="Color.Error" OnClick="DeleteCurrentSession"
                                   Disabled="@(string.IsNullOrEmpty(_selectedSessionId))" />
                </MudTooltip>
            </MudItem>
        </MudGrid>
    </div>

    <MudDivider />

    <div class="chat-messages-container" @ref="_messagesContainer">
        @if (_loadingHistory)
        {
            <div class="d-flex justify-center pa-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
            </div>
        }
        else if (_messages.Count == 0)
        {
            <div class="d-flex flex-column align-center justify-center pa-8" style="height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                    No messages yet. Start the conversation!
                </MudText>
            </div>
        }
        else
        {
            @foreach (var msg in _messages)
            {
                <div class="chat-bubble-row @GetBubbleAlignment(msg.Role)">
                    @if (msg.Role == "system")
                    {
                        <MudPaper Class="chat-bubble chat-bubble-system pa-2 mx-4 my-1" Elevation="0">
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="font-style: italic; opacity: 0.7;">
                                @msg.Content
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="@GetBubbleClass(msg.Role)" Elevation="1">
                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap; word-break: break-word;">
                                @msg.Content
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mt-1" Style="opacity: 0.6;">
                                @msg.Timestamp.LocalDateTime.ToString("HH:mm")
                            </MudText>
                        </MudPaper>
                    }
                </div>
            }

            @if (_waitingForResponse && !_isStreaming)
            {
                <div class="chat-bubble-row chat-align-left">
                    <MudPaper Class="chat-bubble chat-bubble-assistant pa-2 my-1" Elevation="1">
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="width: 80px;" />
                    </MudPaper>
                </div>
            }
        }
    </div>

    <MudDivider />

    <div class="chat-input-bar pa-2">
        <MudGrid Spacing="1">
            <MudItem xs="10">
                <MudTextField @bind-Value="_messageText" Label="Type a message..." Variant="Variant.Outlined"
                              Margin="Margin.Dense" Lines="1" Immediate="true"
                              OnKeyDown="OnInputKeyDown" Disabled="@_waitingForResponse"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Message" />
            </MudItem>
            <MudItem xs="2" Class="d-flex align-center justify-center">
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                               OnClick="SendMessage" Size="Size.Medium"
                               Disabled="@(string.IsNullOrWhiteSpace(_messageText) || _waitingForResponse)" />
            </MudItem>
        </MudGrid>
    </div>
</MudDrawer>

<style>
    .chat-drawer .mud-drawer-content {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .chat-session-bar {
        flex-shrink: 0;
    }

    .chat-messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
        display: flex;
        flex-direction: column;
    }

    .chat-bubble-row {
        display: flex;
        width: 100%;
        margin-bottom: 4px;
    }

    .chat-align-right {
        justify-content: flex-end;
    }

    .chat-align-left {
        justify-content: flex-start;
    }

    .chat-align-center {
        justify-content: center;
    }

    .chat-bubble {
        max-width: 85%;
        border-radius: 12px;
        padding: 8px 12px;
        margin: 2px 0;
    }

    .chat-bubble-user {
        background-color: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary-text) !important;
        border-bottom-right-radius: 4px;
    }

    .chat-bubble-assistant {
        background-color: var(--mud-palette-surface) !important;
        border: 1px solid var(--mud-palette-lines-default);
        border-bottom-left-radius: 4px;
    }

    .chat-bubble-system {
        background: transparent !important;
        max-width: 100%;
    }

    .chat-input-bar {
        flex-shrink: 0;
    }
</style>

@code {
    [Parameter]
    public string PipelineId { get; set; } = "";

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private string _messageText = "";
    private string? _selectedSessionId;
    private bool _loadingHistory;
    private bool _waitingForResponse;
    private bool _isStreaming;
    private List<ChatMessageModel> _messages = [];
    private List<ChatSessionSummary> _sessions = [];
    private ElementReference _messagesContainer;

    private async Task OnOpenChanged(bool open)
    {
        IsOpen = open;
        await IsOpenChanged.InvokeAsync(open);

        if (open && _sessions.Count == 0)
        {
            await LoadSessionsAsync();
        }
    }

    private async Task LoadSessionsAsync()
    {
        try
        {
            var response = await ChatApi.ListSessionsAsync(PipelineId);
            _sessions = response.Sessions.OrderByDescending(s => s.LastActivityAt).ToList();

            if (_sessions.Count > 0 && string.IsNullOrEmpty(_selectedSessionId))
            {
                _selectedSessionId = _sessions[0].SessionId;
                await LoadHistoryAsync(_selectedSessionId);
            }
        }
        catch
        {
            _sessions = [];
        }
    }

    private async Task LoadHistoryAsync(string sessionId)
    {
        _loadingHistory = true;
        StateHasChanged();

        try
        {
            var history = await ChatApi.GetHistoryAsync(PipelineId, sessionId);
            _messages = history.Messages.ToList();
        }
        catch
        {
            _messages = [];
        }
        finally
        {
            _loadingHistory = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task OnSessionSelected(string sessionId)
    {
        _selectedSessionId = sessionId;
        if (!string.IsNullOrEmpty(sessionId))
        {
            await LoadHistoryAsync(sessionId);
        }
    }

    private void StartNewSession()
    {
        _selectedSessionId = null;
        _messages = [];
        StateHasChanged();
    }

    private async Task DeleteCurrentSession()
    {
        if (string.IsNullOrEmpty(_selectedSessionId))
            return;

        try
        {
            await ChatApi.DeleteSessionAsync(PipelineId, _selectedSessionId);
            _sessions.RemoveAll(s => s.SessionId == _selectedSessionId);
            _selectedSessionId = _sessions.FirstOrDefault()?.SessionId;
            _messages = [];

            if (_selectedSessionId != null)
            {
                await LoadHistoryAsync(_selectedSessionId);
            }
            else
            {
                StateHasChanged();
            }
        }
        catch
        {
            // Swallow for now
        }
    }

    private async Task OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        var text = _messageText?.Trim();
        if (string.IsNullOrWhiteSpace(text) || _waitingForResponse)
            return;

        // Add the user message locally
        var userMessage = new ChatMessageModel
        {
            Id = Guid.NewGuid().ToString(),
            Role = "user",
            Content = text,
            Timestamp = DateTimeOffset.Now
        };
        _messages.Add(userMessage);
        _messageText = "";
        _waitingForResponse = true;
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            // Try streaming first, fall back to sync
            await SendMessageStreamingAsync(text);
        }
        catch
        {
            // Streaming failed, fall back to synchronous
            try
            {
                await SendMessageSyncAsync(text);
            }
            catch (Exception ex)
            {
                _messages.Add(new ChatMessageModel
                {
                    Id = Guid.NewGuid().ToString(),
                    Role = "system",
                    Content = $"Error: {ex.Message}",
                    Timestamp = DateTimeOffset.Now
                });
            }
        }
        finally
        {
            _waitingForResponse = false;
            _isStreaming = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task SendMessageStreamingAsync(string text)
    {
        // Add an empty assistant message bubble that we'll fill progressively
        var assistantMessage = new ChatMessageModel
        {
            Id = Guid.NewGuid().ToString(),
            Role = "assistant",
            Content = "",
            Timestamp = DateTimeOffset.Now
        };
        _messages.Add(assistantMessage);
        _isStreaming = true;
        StateHasChanged();
        await ScrollToBottomAsync();

        await foreach (var evt in ChatApi.StreamMessageAsync(PipelineId, text, _selectedSessionId))
        {
            switch (evt.Type)
            {
                case "token":
                    assistantMessage.Content += evt.Token;
                    await InvokeAsync(StateHasChanged);
                    await ScrollToBottomAsync();
                    break;

                case "done":
                    // Finalize with the full content from the server
                    assistantMessage.Content = evt.FullContent ?? assistantMessage.Content;
                    assistantMessage = assistantMessage with { Id = evt.MessageId ?? assistantMessage.Id };
                    _messages[^1] = assistantMessage;

                    if (string.IsNullOrEmpty(_selectedSessionId) && evt.SessionId is not null)
                    {
                        _selectedSessionId = evt.SessionId;
                        await LoadSessionsAsync();
                    }
                    break;

                case "error":
                    // Remove the empty assistant bubble and show error
                    _messages.Remove(assistantMessage);
                    _messages.Add(new ChatMessageModel
                    {
                        Id = Guid.NewGuid().ToString(),
                        Role = "system",
                        Content = $"Error: {evt.Error}",
                        Timestamp = DateTimeOffset.Now
                    });
                    break;
            }
        }
    }

    private async Task SendMessageSyncAsync(string text)
    {
        var response = await ChatApi.SendMessageAsync(PipelineId, text, _selectedSessionId);

        if (string.IsNullOrEmpty(_selectedSessionId))
        {
            _selectedSessionId = response.SessionId;
            await LoadSessionsAsync();
        }

        _messages.Add(new ChatMessageModel
        {
            Id = response.MessageId,
            Role = response.Role,
            Content = response.Content,
            Timestamp = response.Timestamp,
            Metadata = response.Metadata
        });
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.chat-messages-container')?.scrollTo(0, document.querySelector('.chat-messages-container')?.scrollHeight ?? 0)");
        }
        catch
        {
            // JS interop may fail during prerender
        }
    }

    private static string GetBubbleAlignment(string role) => role switch
    {
        "user" => "chat-align-right",
        "system" => "chat-align-center",
        _ => "chat-align-left"
    };

    private static string GetBubbleClass(string role) => role switch
    {
        "user" => "chat-bubble chat-bubble-user pa-2 my-1",
        _ => "chat-bubble chat-bubble-assistant pa-2 my-1"
    };
}
