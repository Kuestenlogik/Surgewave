@using Kuestenlogik.Surgewave.Control.Models.Collaboration

<MudPaper Elevation="2" Class="pa-3">
    <MudText Typo="Typo.h6" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Comment" Class="mr-1" />
        Comments
        @if (_unresolvedCount > 0)
        {
            <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning" Variant="Variant.Text" Class="ml-2">
                @_unresolvedCount
            </MudChip>
        }
    </MudText>

    @* Filter bar *@
    <div class="d-flex align-center gap-2 mb-2">
        <MudChipSet T="string" @bind-SelectedValues="_selectedFilter" SelectionMode="SelectionMode.SingleSelection">
            <MudChip T="string" Value="@("all")" Size="MudBlazor.Size.Small" Variant="Variant.Outlined">All</MudChip>
            <MudChip T="string" Value="@("open")" Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Warning">Open</MudChip>
            <MudChip T="string" Value="@("resolved")" Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Success">Resolved</MudChip>
        </MudChipSet>
        @if (!string.IsNullOrEmpty(FilterNodeId))
        {
            <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Info" OnClose="ClearNodeFilter">
                Node: @FilterNodeId[..Math.Min(8, FilterNodeId.Length)]...
            </MudChip>
        }
    </div>

    @* Comment list *@
    <div style="max-height: 300px; overflow-y: auto;">
        @foreach (var comment in FilteredComments)
        {
            <MudCard Elevation="0" Class="mb-2 pa-2" Style="@(comment.Resolved ? "opacity: 0.6;" : "")">
                <div class="d-flex align-center justify-space-between">
                    <div class="d-flex align-center gap-1">
                        <MudAvatar Size="MudBlazor.Size.Small" Style="font-size: 10px;">
                            @GetInitials(comment.Author)
                        </MudAvatar>
                        <MudText Typo="Typo.caption" Style="font-weight: 600;">@comment.Author</MudText>
                    </div>
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatTime(comment.CreatedAt)
                        </MudText>
                        <MudTooltip Text="@(comment.Resolved ? "Unresolve" : "Resolve")">
                            <MudIconButton Icon="@(comment.Resolved ? Icons.Material.Filled.Undo : Icons.Material.Filled.Check)"
                                           Size="MudBlazor.Size.Small"
                                           Color="@(comment.Resolved ? Color.Default : Color.Success)"
                                           OnClick="() => OnResolveComment.InvokeAsync(comment.Id)" />
                        </MudTooltip>
                    </div>
                </div>
                @if (comment.NodeId != null)
                {
                    <MudChip T="string" Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Info" Class="mt-1">
                        Node: @comment.NodeId[..Math.Min(8, comment.NodeId.Length)]...
                    </MudChip>
                }
                <MudText Typo="Typo.body2" Class="mt-1">@comment.Text</MudText>
            </MudCard>
        }

        @if (!FilteredComments.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                No comments yet
            </MudText>
        }
    </div>

    <MudDivider Class="my-2" />

    @* Add comment form *@
    <div class="d-flex gap-2">
        <MudTextField @bind-Value="_newCommentText" Label="Add a comment..." Variant="Variant.Outlined"
                      Margin="Margin.Dense" Lines="2" Class="flex-grow-1"
                      @onkeydown="HandleCommentKeyDown" />
        <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                       Disabled="@string.IsNullOrWhiteSpace(_newCommentText)"
                       OnClick="SubmitComment" Class="align-self-end" />
    </div>
</MudPaper>

@code {
    [Parameter] public IReadOnlyList<PipelineComment> Comments { get; set; } = [];
    [Parameter] public string? FilterNodeId { get; set; }
    [Parameter] public string UserName { get; set; } = "Anonymous";
    [Parameter] public EventCallback<(string Text, string? NodeId)> OnAddComment { get; set; }
    [Parameter] public EventCallback<string> OnResolveComment { get; set; }
    [Parameter] public EventCallback OnNodeFilterCleared { get; set; }

    private string _newCommentText = "";
    private IReadOnlyCollection<string> _selectedFilter = new[] { "all" };

    private int _unresolvedCount => Comments.Count(c => !c.Resolved);

    private IEnumerable<PipelineComment> FilteredComments
    {
        get
        {
            var filtered = Comments.AsEnumerable();

            if (!string.IsNullOrEmpty(FilterNodeId))
            {
                filtered = filtered.Where(c => c.NodeId == FilterNodeId);
            }

            var filter = _selectedFilter.FirstOrDefault() ?? "all";
            filtered = filter switch
            {
                "open" => filtered.Where(c => !c.Resolved),
                "resolved" => filtered.Where(c => c.Resolved),
                _ => filtered
            };

            return filtered.OrderByDescending(c => c.CreatedAt);
        }
    }

    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(_newCommentText)) return;
        await OnAddComment.InvokeAsync((_newCommentText.Trim(), FilterNodeId));
        _newCommentText = "";
    }

    private async Task HandleCommentKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey)
        {
            await SubmitComment();
        }
    }

    private void ClearNodeFilter()
    {
        OnNodeFilterCleared.InvokeAsync();
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    private static string FormatTime(DateTimeOffset time)
    {
        var ago = DateTimeOffset.UtcNow - time;
        return ago.TotalMinutes < 1 ? "just now"
             : ago.TotalMinutes < 60 ? $"{(int)ago.TotalMinutes}m ago"
             : ago.TotalHours < 24 ? $"{(int)ago.TotalHours}h ago"
             : time.ToString("MMM dd HH:mm");
    }
}
