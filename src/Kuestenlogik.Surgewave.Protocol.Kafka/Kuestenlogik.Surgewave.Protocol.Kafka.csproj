<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <Content Include="plugin.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="pluginsettings.json" Condition="Exists('pluginsettings.json')" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- MSBuild task: surgewave plugins pack/install (Kuestenlogik.Surgewave.Build) -->
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Build\Kuestenlogik.Surgewave.Build.csproj" PrivateAssets="all" />
  </ItemGroup>
  <Import Project="..\Kuestenlogik.Surgewave.Build\build\Kuestenlogik.Surgewave.Build.targets" />

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Core\Kuestenlogik.Surgewave.Core.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Protocol\Kuestenlogik.Surgewave.Protocol.csproj" />
    <!-- IProtocolPlugin contract for SurgewaveKafkaProtocolPlugin (#58). No cycle:
         Plugins references only Core + Plugins.Packaging, never Protocol.Kafka. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Plugins\Kuestenlogik.Surgewave.Plugins.csproj" />
    <!-- Protocol-neutral coordinator contracts (#59 part b). The Kafka DTO adapters
         (Consumer/Share/Streams/Transaction ApiHandlers) live here and target these
         interfaces. Coordination is a leaf assembly, so there is no reference cycle. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Coordination\Kuestenlogik.Surgewave.Coordination.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Broker" />
    <InternalsVisibleTo Include="surgewave-broker" />
  </ItemGroup>

</Project>
