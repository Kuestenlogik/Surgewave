<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <Content Include="plugin.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="pluginsettings.json" Condition="Exists('pluginsettings.json')" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- MSBuild task: surgewave plugins pack/install (Kuestenlogik.Surgewave.Build) -->
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Build\Kuestenlogik.Surgewave.Build.csproj" PrivateAssets="all" />
  </ItemGroup>
  <Import Project="..\Kuestenlogik.Surgewave.Build\build\Kuestenlogik.Surgewave.Build.targets" />

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Core\Kuestenlogik.Surgewave.Core.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Protocol\Kuestenlogik.Surgewave.Protocol.csproj" />
    <!-- IProtocolPlugin contract for SurgewaveKafkaProtocolPlugin (#58). No cycle:
         Plugins references only Core + Plugins.Packaging, never Protocol.Kafka. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Plugins\Kuestenlogik.Surgewave.Plugins.csproj" />
    <!-- Protocol-neutral coordinator contracts (#59 part b). The Kafka DTO adapters
         (Consumer/Share/Streams/Transaction ApiHandlers) live here and target these
         interfaces. Coordination is a leaf assembly, so there is no reference cycle. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Coordination\Kuestenlogik.Surgewave.Coordination.csproj" />
    <!-- Neutral broker service seams (#59 b4-tier2 increment D): the relocated Kafka
         handlers (Quota/DelegationToken/Telemetry/Data) depend on these interfaces, not
         the concrete broker services. Broker.Abstractions references Core only — the
         one-way triangle Protocol.Kafka -> Broker.Abstractions <- Broker holds. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Broker.Abstractions\Kuestenlogik.Surgewave.Broker.Abstractions.csproj" />
    <!-- #59 b5 ATOMIC FLIP: the Clustering<->Protocol.Kafka edge is inverted. The relocated
         inter-broker/control-plane handlers + ControllerClient/BrokerLifecycleManager reach
         ClusterState/ClusterController/ReplicaManager/Raft here. Clustering no longer references
         Protocol.Kafka, so there is no cycle. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Clustering\Kuestenlogik.Surgewave.Clustering.csproj" />
  </ItemGroup>

  <!-- SASL/OAUTHBEARER (KIP-936) validator moved in with the SASL stack (#59 b5). -->
  <ItemGroup>
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" />
    <PackageReference Include="Microsoft.IdentityModel.Protocols.OpenIdConnect" />
    <!-- IHttpClientFactory for the OAUTHBEARER JWKS fetch (moved in with the SASL stack). -->
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Broker" />
    <InternalsVisibleTo Include="surgewave-broker" />
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Broker.Tests" />
  </ItemGroup>

</Project>
