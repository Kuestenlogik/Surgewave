  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Streams.InteractiveQueries\Kuestenlogik.Surgewave.Streams.InteractiveQueries.csproj" />
  </ItemGroup>

</Project>
