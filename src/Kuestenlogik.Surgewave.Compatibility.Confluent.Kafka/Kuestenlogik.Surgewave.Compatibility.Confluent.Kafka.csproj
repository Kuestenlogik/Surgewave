<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Confluent.Kafka API compatibility layer for Surgewave. Enables zero-code-change migration from Kafka to Surgewave.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- CA1707: Confluent.Kafka API compatibility requires matching their naming -->
    <NoWarn>$(NoWarn);CA1707</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Client\Kuestenlogik.Surgewave.Client.csproj" />
    <!-- #59: the Confluent-compat producer/consumer/admin builders build Kafka-wire clients
         (ProtocolType.Kafka), which SurgewaveClientBuilder resolves from Client.Kafka by
         reflection — so that assembly must be present in this shim's bin. -->
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Client.Kafka\Kuestenlogik.Surgewave.Client.Kafka.csproj" />
  </ItemGroup>

</Project>
