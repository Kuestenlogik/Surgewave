<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Kuestenlogik.Surgewave.Schema.Registry.Handlers</RootNamespace>
    <Description>Schemaless binary schema handlers (CBOR, Hyperion, MemoryPack, MessagePack, Orleans) for the Surgewave Schema Registry. These formats are self-describing and version internally, so validation always succeeds and every schema is compatible — the handlers carry no format serializer dependency.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Schema.Registry\Kuestenlogik.Surgewave.Schema.Registry.csproj" />
  </ItemGroup>
</Project>
