<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Surgewave PostgreSQL wire protocol adapter — lets psql and any PostgreSQL client query Surgewave topics using SQL</Description>
    <PackageTags>surgewave;kafka;protocol;postgresql;postgres;sql;psql</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="plugin.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="pluginsettings.json" Condition="Exists('pluginsettings.json')" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- MSBuild task: surgewave plugins pack/install (Kuestenlogik.Surgewave.Build) -->
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Build\Kuestenlogik.Surgewave.Build.csproj" PrivateAssets="all" />
  </ItemGroup>
  <Import Project="..\Kuestenlogik.Surgewave.Build\build\Kuestenlogik.Surgewave.Build.targets" />

  <ItemGroup>
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Protocol.PostgreSql.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Core\Kuestenlogik.Surgewave.Core.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Plugins\Kuestenlogik.Surgewave.Plugins.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Streams\Kuestenlogik.Surgewave.Streams.csproj" />
  </ItemGroup>

</Project>
