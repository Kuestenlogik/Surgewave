<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Kuestenlogik.Surgewave.Connect</RootNamespace>
    <OutputType>Library</OutputType>
    <IsPackable>true</IsPackable>
    <Description>Surgewave Connect framework for building source and sink connectors. Compatible with Kafka Connect concepts.</Description>
    <PackageTags>surgewave;kafka;connect;connectors;etl;integration;source;sink</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Connect.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Surgewave.Connect.Hosting" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Core\Kuestenlogik.Surgewave.Core.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Client\Kuestenlogik.Surgewave.Client.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Plugins\Kuestenlogik.Surgewave.Plugins.csproj" />
    <ProjectReference Include="..\Kuestenlogik.Surgewave.Connect.Abstractions\Kuestenlogik.Surgewave.Connect.Abstractions.csproj" />
  </ItemGroup>

</Project>
